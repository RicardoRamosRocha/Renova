@{
    ViewData["Title"] = "Login | Renova";
    ViewData["MetaDescription"] = "Acesso seguro ao painel Renova.";
    ViewData["MetaKeywords"] = "Renova, login, gestao clinica";
    var returnUrl = ViewBag.ReturnUrl as string ?? "/Admin";
    var hasError = ViewBag.HasError is true;
}

<main id="conteudo" class="login-premium-page">
    <div class="login-theme-toggle" aria-label="Alternar tema visual">
        <button type="button" class="is-active" data-login-theme="light">Claro</button>
        <button type="button" data-login-theme="dark">Escuro</button>
    </div>

    <section class="login-premium-shell" aria-label="Acesso ao sistema Renova">
        <aside class="login-brand-panel">
            <a class="login-brand-logo" asp-controller="Home" asp-action="Index" aria-label="Renova">
                <span aria-hidden="true">R</span>
                <strong>Renova</strong>
            </a>

            <div class="login-brand-copy">
                <span class="login-brand-title">Plataforma Cl&iacute;nica</span>
                <h1>Cuidado que transforma. Gest&atilde;o que evolui.</h1>
                <p>
                    Uma plataforma completa para acolhimento, acompanhamento e transforma&ccedil;&atilde;o de vidas.
                    Tecnologia, empatia e seguran&ccedil;a em cada etapa do cuidado.
                </p>
            </div>

            <div class="login-feature-grid" aria-label="Recursos principais">
                <article class="login-feature-card">
                    <span aria-hidden="true">+</span>
                    <strong>Acolhimento</strong>
                    <p>Gest&atilde;o completa de acolhidos e fam&iacute;lias</p>
                </article>
                <article class="login-feature-card">
                    <span aria-hidden="true">+</span>
                    <strong>Cl&iacute;nico</strong>
                    <p>Prontu&aacute;rios, evolu&ccedil;&otilde;es e agenda integrada</p>
                </article>
                <article class="login-feature-card">
                    <span aria-hidden="true">+</span>
                    <strong>EAD</strong>
                    <p>Cursos, trilhas e acompanhamento</p>
                </article>
            </div>

            <div class="login-stats-grid" aria-label="Indicadores do Renova">
                <article class="login-stats-card"><strong>100%</strong><span>Seguran&ccedil;a de dados e LGPD</span></article>
                <article class="login-stats-card"><strong>+10</strong><span>M&oacute;dulos integrados</span></article>
                <article class="login-stats-card"><strong>Dados</strong><span>Relat&oacute;rios e dashboards em tempo real</span></article>
                <article class="login-stats-card"><strong>Confi&aacute;vel</strong><span>Para institui&ccedil;&otilde;es e profissionais</span></article>
            </div>

            <p class="login-brand-footer">A tecnologia &eacute; o nosso meio. O cuidado &eacute; o nosso prop&oacute;sito.</p>
        </aside>

        <section class="login-auth-panel">
            <div class="login-auth-card">
                <div class="login-auth-heading">
                    <span>Acesso restrito</span>
                    <h2>Entrar no Renova</h2>
                    <p>Use seu email institucional para acessar o painel administrativo com seguran&ccedil;a.</p>
                </div>

                @if (hasError)
                {
                    <div class="login-alert" role="alert">
                        N&atilde;o foi poss&iacute;vel entrar. Confira seu email, senha ou status do usu&aacute;rio.
                    </div>
                }

                <form class="login-premium-form" action="/auth/web-login" method="post">
                    <input type="hidden" name="returnUrl" value="@returnUrl" />

                    <label class="login-input-group">
                        <span>Email institucional</span>
                        <div>
                            <i aria-hidden="true">&#64;</i>
                            <input name="email" type="email" autocomplete="username" placeholder="seu@email.com.br" required />
                        </div>
                    </label>

                    <label class="login-input-group">
                        <span>Senha</span>
                        <div>
                            <i aria-hidden="true">#</i>
                            <input id="login-password" name="password" type="password" autocomplete="current-password" placeholder="Digite sua senha" required />
                            <button class="login-password-toggle" type="button" aria-label="Mostrar ou ocultar senha" aria-controls="login-password">Olho</button>
                        </div>
                    </label>

                    <div class="login-form-row">
                        <label class="login-remember">
                            <input name="rememberMe" type="checkbox" value="true" />
                            <span>Lembrar de mim</span>
                        </label>
                        <a href="/login">Esqueci minha senha</a>
                    </div>

                    <button class="login-submit-button" type="submit">Entrar no sistema</button>
                </form>

                <p class="login-auth-footer">Tecnologia com prop&oacute;sito. Pessoas no centro.</p>
            </div>
        </section>
    </section>
</main>

<script>
    (() => {
        const page = document.querySelector(".login-premium-page");
        const password = document.querySelector("#login-password");
        const passwordToggle = document.querySelector(".login-password-toggle");
        const themeButtons = document.querySelectorAll("[data-login-theme]");

        passwordToggle?.addEventListener("click", () => {
            const isPassword = password.type === "password";
            password.type = isPassword ? "text" : "password";
            passwordToggle.textContent = isPassword ? "Ocultar" : "Olho";
        });

        themeButtons.forEach((button) => {
            button.addEventListener("click", () => {
                const theme = button.dataset.loginTheme;
                page.classList.toggle("is-dark", theme === "dark");
                themeButtons.forEach((item) => item.classList.toggle("is-active", item === button));
            });
        });
    })();
</script>
