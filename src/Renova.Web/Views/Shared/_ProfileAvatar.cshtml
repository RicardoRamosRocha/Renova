@model Renova.Web.ViewModels.ProfileAvatarViewModel
@{
    static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "?";
        }

        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1)
        {
            return parts[0][..1].ToUpperInvariant();
        }

        return string.Concat(parts[0][..1], parts[^1][..1]).ToUpperInvariant();
    }

    var initials = Initials(Model.Name);
    var sizeClass = string.IsNullOrWhiteSpace(Model.Size) ? "sm" : Model.Size;
}

<span class="profile-avatar profile-avatar-@sizeClass" aria-hidden="true">
    @if (!string.IsNullOrWhiteSpace(Model.PhotoUrl))
    {
        <img class="profile-avatar-image" src="@Model.PhotoUrl" alt="" />
    }
    else
    {
        <span class="profile-avatar-placeholder">@initials</span>
    }
</span>
