@page "/login"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore

@inject IServiceScopeFactory ScopeFactory
@inject UserSession Session
@inject NavigationManager Navigation

<PageTitle>Login</PageTitle>

<section class="page-header compact">
    <div>
        <p class="eyebrow">Acesso</p>
        <h1>Entrar no Renova</h1>
        <p>Crie o primeiro administrador ou entre com um usuario existente.</p>
    </div>
</section>

<div class="form-panel access-panel">
    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <div class="alert @MessageClass">@Message</div>
    }

    @if (Session.IsAuthenticated)
    {
        <div class="session-card">
            <span>Sessao ativa</span>
            <strong>@Session.User?.FullName</strong>
            <p>@string.Join(", ", Session.Roles)</p>
        </div>
        <form action="/auth/web-logout" method="post">
            <button class="btn btn-outline-secondary" type="submit">Sair</button>
        </form>
    }
    else
    {
        @if (!HasUsers)
        {
            <h2>Primeiro administrador</h2>
            <EditForm Model="RegisterModel" OnValidSubmit="CreateAdministrator">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <label>Nome completo</label>
                <InputText class="form-control" @bind-Value="RegisterModel.FullName" />

                <label>Email</label>
                <InputText class="form-control" @bind-Value="RegisterModel.Email" />

                <label>Telefone</label>
                <InputText class="form-control" @bind-Value="RegisterModel.PhoneNumber" />

                <label>Senha</label>
                <InputText class="form-control" type="password" @bind-Value="RegisterModel.Password" />

                <button class="btn btn-primary" type="submit">Criar administrador</button>
            </EditForm>

            <hr />
        }

        <h2>Login</h2>
        @if (HasLoginError)
        {
            <div class="alert alert-danger">Email ou senha invalidos.</div>
        }
        <form action="/auth/web-login" method="post">
            <input name="returnUrl" type="hidden" value="@ReturnUrl" />

            <label>Email</label>
            <input class="form-control" name="email" type="email" />

            <label>Senha</label>
            <input class="form-control" name="password" type="password" />

            <button class="btn btn-primary" type="submit">Entrar</button>
        </form>
    }
</div>

@code {
    private bool HasUsers;
    private bool HasLoginError;
    private string? Message;
    private string MessageClass = "alert-info";
    private string ReturnUrl = "/Admin";
    private RegisterForm RegisterModel { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        using var scope = ScopeFactory.CreateScope();

        var userManager = scope.ServiceProvider
            .GetRequiredService<UserManager<ApplicationUser>>();

        HasUsers = await userManager.Users.AnyAsync();

        var currentUri = Navigation.ToAbsoluteUri(Navigation.Uri);

        HasLoginError = currentUri.Query.Contains("error=1", StringComparison.OrdinalIgnoreCase);
        ReturnUrl = GetQueryValue(currentUri.Query, "ReturnUrl") ?? "/Admin";
    }

    private static string? GetQueryValue(string query, string key)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            return null;
        }

        foreach (var segment in query.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var pair = segment.Split('=', 2);
            if (pair.Length == 2 && string.Equals(Uri.UnescapeDataString(pair[0]), key, StringComparison.OrdinalIgnoreCase))
            {
                return Uri.UnescapeDataString(pair[1]);
            }
        }

        return null;
    }

    private async Task CreateAdministrator()
    {
        using var scope = ScopeFactory.CreateScope();

        var userManager = scope.ServiceProvider
            .GetRequiredService<UserManager<ApplicationUser>>();

        var roleManager = scope.ServiceProvider
            .GetRequiredService<RoleManager<IdentityRole>>();

        await EnsureRoles(roleManager);

        var user = new ApplicationUser
        {
            FullName = RegisterModel.FullName.Trim(),
            UserName = RegisterModel.Email.Trim(),
            Email = RegisterModel.Email.Trim(),
            PhoneNumber = RegisterModel.PhoneNumber.Trim(),
            EmailConfirmed = true,
            IsActive = true,
            CreatedAt = DateTime.UtcNow
        };

        var result = await userManager.CreateAsync(user, RegisterModel.Password);

        if (!result.Succeeded)
        {
            ShowError(string.Join(" ", result.Errors.Select(error => error.Description)));
            return;
        }

        await userManager.AddToRoleAsync(user, ApplicationRoles.Administrator);

        HasUsers = true;
        ShowSuccess("Administrador criado. Entre com o email e senha cadastrados.");
    }

    private static async Task EnsureRoles(RoleManager<IdentityRole> roleManager)
    {
        foreach (var roleName in ApplicationRoles.All)
        {
            if (!await roleManager.RoleExistsAsync(roleName))
            {
                await roleManager.CreateAsync(new IdentityRole(roleName));
            }
        }
    }

    private void ShowError(string message)
    {
        Message = message;
        MessageClass = "alert-danger";
    }

    private void ShowSuccess(string message)
    {
        Message = message;
        MessageClass = "alert-success";
    }

    private sealed class RegisterForm
    {
        public string FullName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string PhoneNumber { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
