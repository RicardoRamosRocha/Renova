@page "/login"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject RoleManager<IdentityRole> RoleManager
@inject UserSession Session
@inject NavigationManager Navigation

<PageTitle>Login</PageTitle>

<section class="page-header compact">
    <div>
        <p class="eyebrow">Acesso</p>
        <h1>Entrar no Renova</h1>
        <p>Crie o primeiro administrador ou acesse com um usuário existente.</p>
    </div>
</section>

<div class="form-panel">
    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <div class="alert @MessageClass">@Message</div>
    }

    @if (!HasUsers)
    {
        <h2>Primeiro administrador</h2>
        <EditForm Model="RegisterModel" OnValidSubmit="CreateAdministrator">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <label>Nome completo</label>
            <InputText class="form-control" @bind-Value="RegisterModel.FullName" />

            <label>Email</label>
            <InputText class="form-control" @bind-Value="RegisterModel.Email" />

            <label>Telefone</label>
            <InputText class="form-control" @bind-Value="RegisterModel.PhoneNumber" />

            <label>Senha</label>
            <InputText class="form-control" type="password" @bind-Value="RegisterModel.Password" />

            <button class="btn btn-primary" type="submit">Criar administrador</button>
        </EditForm>
    }

    <h2>Login</h2>
    <EditForm Model="LoginModel" OnValidSubmit="LoginUser">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <label>Email</label>
        <InputText class="form-control" @bind-Value="LoginModel.Email" />

        <label>Senha</label>
        <InputText class="form-control" type="password" @bind-Value="LoginModel.Password" />

        <button class="btn btn-primary" type="submit">Entrar</button>
    </EditForm>
</div>

@code {
    private bool HasUsers;
    private string? Message;
    private string MessageClass = "alert-info";
    private LoginForm LoginModel { get; set; } = new();
    private RegisterForm RegisterModel { get; set; } = new();

    protected override void OnInitialized()
    {
        HasUsers = UserManager.Users.Any();
    }

    private async Task CreateAdministrator()
    {
        foreach (var role in ApplicationRoles.Seed)
        {
            if (!await RoleManager.RoleExistsAsync(role.Name!))
            {
                await RoleManager.CreateAsync(new IdentityRole(role.Name!));
            }
        }

        var user = new ApplicationUser
        {
            FullName = RegisterModel.FullName.Trim(),
            UserName = RegisterModel.Email.Trim(),
            Email = RegisterModel.Email.Trim(),
            PhoneNumber = RegisterModel.PhoneNumber.Trim(),
            EmailConfirmed = true,
            IsActive = true,
            CreatedAt = DateTime.UtcNow
        };

        var result = await UserManager.CreateAsync(user, RegisterModel.Password);

        if (!result.Succeeded)
        {
            ShowError(string.Join(" ", result.Errors.Select(error => error.Description)));
            return;
        }

        await UserManager.AddToRoleAsync(user, ApplicationRoles.Administrator);
        HasUsers = true;
        ShowSuccess("Administrador criado. Você já pode entrar.");
    }

    private async Task LoginUser()
    {
        var user = await UserManager.FindByEmailAsync(LoginModel.Email.Trim());

        if (user is null || !user.IsActive)
        {
            ShowError("Usuário não encontrado ou inativo.");
            return;
        }

        var result = await SignInManager.CheckPasswordSignInAsync(user, LoginModel.Password, false);

        if (!result.Succeeded)
        {
            ShowError("Email ou senha inválidos.");
            return;
        }

        var roles = await UserManager.GetRolesAsync(user);
        Session.SignIn(user, roles.ToArray());
        Navigation.NavigateTo("/students");
    }

    private void ShowError(string message)
    {
        Message = message;
        MessageClass = "alert-danger";
    }

    private void ShowSuccess(string message)
    {
        Message = message;
        MessageClass = "alert-success";
    }

    private sealed class LoginForm
    {
        public string Email { get; set; } = string.Empty;

        public string Password { get; set; } = string.Empty;
    }

    private sealed class RegisterForm
    {
        public string FullName { get; set; } = string.Empty;

        public string Email { get; set; } = string.Empty;

        public string PhoneNumber { get; set; } = string.Empty;

        public string Password { get; set; } = string.Empty;
    }
}
