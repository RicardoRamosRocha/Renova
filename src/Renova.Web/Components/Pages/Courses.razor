@page "/courses"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = ApplicationRoles.CourseManagementRoles)]
@inject IDbContextFactory<AppDbContext> DbFactory
@inject UserSession Session

<PageTitle>Cursos</PageTitle>

<section class="page-header compact">
    <div>
        <p class="eyebrow">EAD</p>
        <h1>Cursos</h1>
        <p>Monte cursos, modulos e aulas para o portal de aprendizagem.</p>
    </div>
</section>

@if (!Session.IsAuthenticated)
{
    <div class="alert alert-warning">Faca login para acessar o cadastro de cursos.</div>
    <a class="btn btn-primary" href="login">Entrar</a>
}
else if (!Session.CanManageEad)
{
    <div class="alert alert-warning">Seu perfil nao pode gerenciar cursos.</div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <div class="alert @MessageClass">@Message</div>
    }

    <div class="split-grid wide-left">
        <div class="form-panel">
            <h2>Novo curso</h2>
            <EditForm Model="CourseForm" OnValidSubmit="SaveCourse">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <label>Titulo</label>
                <InputText class="form-control" @bind-Value="CourseForm.Title" />

                <label>Descricao</label>
                <InputTextArea class="form-control text-area" @bind-Value="CourseForm.Description" />

                <label class="checkbox-line">
                    <InputCheckbox class="form-check-input" @bind-Value="CourseForm.IsActive" />
                    Curso ativo
                </label>

                <button class="btn btn-primary" type="submit">Salvar curso</button>
            </EditForm>

            <hr />

            <h2>Novo modulo</h2>
            @if (CourseList.Count == 0)
            {
                <p class="muted">Cadastre um curso antes de adicionar modulos.</p>
            }
            else
            {
                <EditForm Model="ModuleForm" OnValidSubmit="SaveModule">
                    <DataAnnotationsValidator />

                    <label>Curso</label>
                    <InputSelect class="form-select" @bind-Value="ModuleForm.CourseId">
                        <option value="">Selecione</option>
                        @foreach (var course in CourseList)
                        {
                            <option value="@course.Id">@course.Title</option>
                        }
                    </InputSelect>

                    <label>Titulo</label>
                    <InputText class="form-control" @bind-Value="ModuleForm.Title" />

                    <label>Descricao</label>
                    <InputTextArea class="form-control text-area" @bind-Value="ModuleForm.Description" />

                    <label>Ordem</label>
                    <InputNumber class="form-control" @bind-Value="ModuleForm.Order" />

                    <button class="btn btn-primary" type="submit">Adicionar modulo</button>
                </EditForm>
            }

            <hr />

            <h2>Nova aula</h2>
            @if (ModuleList.Count == 0)
            {
                <p class="muted">Cadastre um modulo antes de adicionar aulas.</p>
            }
            else
            {
                <EditForm Model="LessonForm" OnValidSubmit="SaveLesson">
                    <DataAnnotationsValidator />

                    <label>Modulo</label>
                    <InputSelect class="form-select" @bind-Value="LessonForm.CourseModuleId">
                        <option value="">Selecione</option>
                        @foreach (var module in ModuleList)
                        {
                            <option value="@module.Id">@module.Course.Title - @module.Title</option>
                        }
                    </InputSelect>

                    <label>Titulo</label>
                    <InputText class="form-control" @bind-Value="LessonForm.Title" />

                    <label>Descricao</label>
                    <InputTextArea class="form-control text-area" @bind-Value="LessonForm.Description" />

                    <label>Provedor de video</label>
                    <InputText class="form-control" @bind-Value="LessonForm.VideoProvider" />

                    <label>ID externo do video</label>
                    <InputText class="form-control" @bind-Value="LessonForm.VideoExternalId" />

                    <label>Duracao em minutos</label>
                    <InputNumber class="form-control" @bind-Value="LessonForm.DurationInMinutes" />

                    <label>Ordem</label>
                    <InputNumber class="form-control" @bind-Value="LessonForm.Order" />

                    <button class="btn btn-primary" type="submit">Adicionar aula</button>
                </EditForm>
            }
        </div>

        <div class="data-panel">
            <div class="panel-title">
                <h2>Catalogo EAD</h2>
                <button class="btn btn-sm btn-outline-secondary" @onclick="LoadCourses">Atualizar</button>
            </div>

            @if (CourseList.Count == 0)
            {
                <p class="muted">Nenhum curso cadastrado.</p>
            }
            else
            {
                <div class="course-stack">
                    @foreach (var course in CourseList)
                    {
                        <article class="course-item">
                            <div class="course-heading">
                                <div>
                                    <h3>@course.Title</h3>
                                    <p>@course.Description</p>
                                </div>
                                <span class="status-pill @(course.IsActive ? "active" : "inactive")">
                                    @(course.IsActive ? "Ativo" : "Inativo")
                                </span>
                            </div>

                            @if (course.Modules.Count == 0)
                            {
                                <p class="muted">Sem modulos cadastrados.</p>
                            }
                            else
                            {
                                <div class="module-list">
                                    @foreach (var module in course.Modules.OrderBy(module => module.Order))
                                    {
                                        <section class="module-item">
                                            <h4>@module.Order. @module.Title</h4>
                                            <p>@module.Description</p>

                                            @if (module.Lessons.Count == 0)
                                            {
                                                <small class="muted">Sem aulas cadastradas.</small>
                                            }
                                            else
                                            {
                                                <table class="table table-sm">
                                                    <thead>
                                                        <tr>
                                                            <th>Aula</th>
                                                            <th>Video</th>
                                                            <th>Min</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var lesson in module.Lessons.OrderBy(lesson => lesson.Order))
                                                        {
                                                            <tr>
                                                                <td>@lesson.Order. @lesson.Title</td>
                                                                <td>@lesson.VideoProvider / @lesson.VideoExternalId</td>
                                                                <td>@lesson.DurationInMinutes</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            }
                                        </section>
                                    }
                                </div>
                            }
                        </article>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private List<Course> CourseList { get; set; } = [];
    private List<CourseModule> ModuleList { get; set; } = [];
    private CourseFormModel CourseForm { get; set; } = new();
    private ModuleFormModel ModuleForm { get; set; } = new();
    private LessonFormModel LessonForm { get; set; } = new();
    private string? Message;
    private string MessageClass = "alert-success";

    protected override async Task OnInitializedAsync()
    {
        if (Session.IsAuthenticated && Session.CanManageEad)
        {
            await LoadCourses();
        }
    }

    private async Task LoadCourses()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        CourseList = await db.Courses
            .Include(course => course.Modules)
            .ThenInclude(module => module.Lessons)
            .OrderBy(course => course.Title)
            .ToListAsync();

        ModuleList = await db.CourseModules
            .Include(module => module.Course)
            .OrderBy(module => module.Course.Title)
            .ThenBy(module => module.Order)
            .ToListAsync();
    }

    private async Task SaveCourse()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        db.Courses.Add(new Course
        {
            Title = CourseForm.Title.Trim(),
            Description = CourseForm.Description.Trim(),
            IsActive = CourseForm.IsActive,
            CreatedAt = DateTime.UtcNow
        });

        await db.SaveChangesAsync();
        CourseForm = new();
        ShowSuccess("Curso cadastrado.");
        await LoadCourses();
    }

    private async Task SaveModule()
    {
        if (!Guid.TryParse(ModuleForm.CourseId, out var courseId))
        {
            ShowError("Selecione um curso para o modulo.");
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();

        db.CourseModules.Add(new CourseModule
        {
            CourseId = courseId,
            Title = ModuleForm.Title.Trim(),
            Description = ModuleForm.Description.Trim(),
            Order = ModuleForm.Order,
            CreatedAt = DateTime.UtcNow
        });

        try
        {
            await db.SaveChangesAsync();
        }
        catch (DbUpdateException)
        {
            ShowError("Ja existe um modulo com esta ordem neste curso.");
            return;
        }

        ShowSuccess("Modulo cadastrado.");
        ModuleForm = new();
        await LoadCourses();
    }

    private async Task SaveLesson()
    {
        if (!Guid.TryParse(LessonForm.CourseModuleId, out var moduleId))
        {
            ShowError("Selecione um modulo para a aula.");
            return;
        }

        await using var db = await DbFactory.CreateDbContextAsync();

        db.Lessons.Add(new Lesson
        {
            CourseModuleId = moduleId,
            Title = LessonForm.Title.Trim(),
            Description = LessonForm.Description.Trim(),
            VideoProvider = LessonForm.VideoProvider.Trim(),
            VideoExternalId = LessonForm.VideoExternalId.Trim(),
            DurationInMinutes = LessonForm.DurationInMinutes,
            Order = LessonForm.Order,
            CreatedAt = DateTime.UtcNow
        });

        try
        {
            await db.SaveChangesAsync();
        }
        catch (DbUpdateException)
        {
            ShowError("Ja existe uma aula com esta ordem neste modulo.");
            return;
        }

        ShowSuccess("Aula cadastrada.");
        LessonForm = new();
        await LoadCourses();
    }

    private void ShowSuccess(string message)
    {
        MessageClass = "alert-success";
        Message = message;
    }

    private void ShowError(string message)
    {
        MessageClass = "alert-danger";
        Message = message;
    }

    private sealed class CourseFormModel
    {
        public string Title { get; set; } = string.Empty;

        public string Description { get; set; } = string.Empty;

        public bool IsActive { get; set; } = true;
    }

    private sealed class ModuleFormModel
    {
        public string CourseId { get; set; } = string.Empty;

        public string Title { get; set; } = string.Empty;

        public string Description { get; set; } = string.Empty;

        public int Order { get; set; } = 1;
    }

    private sealed class LessonFormModel
    {
        public string CourseModuleId { get; set; } = string.Empty;

        public string Title { get; set; } = string.Empty;

        public string Description { get; set; } = string.Empty;

        public string VideoProvider { get; set; } = "YouTube";

        public string VideoExternalId { get; set; } = string.Empty;

        public int DurationInMinutes { get; set; } = 10;

        public int Order { get; set; } = 1;
    }
}
