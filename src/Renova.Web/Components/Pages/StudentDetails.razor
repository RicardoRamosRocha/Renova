@page "/students/{Id:guid}"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using Renova.Domain.Entities
@using Renova.Infrastructure.Data
@using Renova.Infrastructure.Identity

@attribute [Authorize(Roles = ApplicationRoles.StudentRecordRoles)]

@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Detalhes do Aluno</PageTitle>

@if (Student is null)
{
    <div class="alert alert-warning">
        Aluno não encontrado.
    </div>

    <a class="btn btn-secondary" href="/students">Voltar</a>
}
else
{
    <section class="page-header compact">
        <div>
            <p class="eyebrow">CRM / Alunos</p>
            <h1>@Student.FullName</h1>
            <p>Detalhes cadastrais e visão inicial do acompanhamento.</p>
        </div>

        <div>
            <a class="btn btn-secondary" href="/students">Voltar</a>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <div class="alert alert-success">@Message</div>
    }

    <div class="split-grid">
        <div class="form-panel">
            <h2>Editar dados</h2>

            <EditForm Model="Form" OnValidSubmit="SaveChanges">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <label>Nome completo</label>
                <InputText class="form-control" @bind-Value="Form.FullName" />

                <label>Nascimento</label>
                <InputDate class="form-control" @bind-Value="Form.BirthDate" />

                <label>CPF</label>
                <InputText class="form-control" @bind-Value="Form.CPF" />

                <label>Telefone</label>
                <InputText class="form-control" @bind-Value="Form.Phone" />

                <label>Email</label>
                <InputText class="form-control" @bind-Value="Form.Email" />

                <label>Endereço</label>
                <InputText class="form-control" @bind-Value="Form.Address" />

                <label>Status</label>
                <InputSelect class="form-control" @bind-Value="Form.Status">
                    <option value="1">Ativo</option>
                    <option value="2">Inativo</option>
                    <option value="3">Em acompanhamento</option>
                    <option value="4">Concluído</option>
                </InputSelect>

                <label>Admissão</label>
                <InputDate class="form-control" @bind-Value="Form.AdmissionDate" />

                <button class="btn btn-primary" type="submit">Salvar alterações</button>
            </EditForm>
        </div>

        <div class="data-panel">
            <h2>Resumo</h2>

            <p><strong>Nome:</strong> @Student.FullName</p>
            <p><strong>CPF:</strong> @Student.CPF</p>
            <p><strong>Telefone:</strong> @Student.Phone</p>
            <p><strong>Email:</strong> @(Student.Email ?? "-")</p>
            <p><strong>Endereço:</strong> @(Student.Address ?? "-")</p>
            <p><strong>Status:</strong> @GetStatusLabel(Student.Status)</p>
            <p><strong>Admissão:</strong> @Student.AdmissionDate.ToString("dd/MM/yyyy")</p>
            <p><strong>Criado em:</strong> @Student.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
        </div>
    </div>

    <div class="data-panel mt-4">
        <h2>Próximas etapas</h2>

        <div class="access-chip-list">
            <span class="access-chip">Familiares</span>
            <span class="access-chip">Prontuário</span>
            <span class="access-chip">Evoluções</span>
            <span class="access-chip">Atendimentos</span>
            <span class="access-chip">EAD</span>
            <span class="access-chip">Financeiro</span>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private Student? Student { get; set; }
    private StudentForm Form { get; set; } = new();
    private string? Message;

    protected override async Task OnInitializedAsync()
    {
        await LoadStudent();
    }

    private async Task LoadStudent()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        Student = await db.Students
            .AsNoTracking()
            .FirstOrDefaultAsync(student => student.Id == Id);

        if (Student is null)
        {
            return;
        }

        Form = new StudentForm
        {
            FullName = Student.FullName,
            BirthDate = Student.BirthDate,
            CPF = Student.CPF,
            Phone = Student.Phone,
            Email = Student.Email,
            Address = Student.Address,
            Status = Student.Status,
            AdmissionDate = Student.AdmissionDate
        };
    }

    private async Task SaveChanges()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var student = await db.Students
            .FirstOrDefaultAsync(student => student.Id == Id);

        if (student is null)
        {
            return;
        }

        student.FullName = Form.FullName.Trim();
        student.BirthDate = DateTime.SpecifyKind(Form.BirthDate, DateTimeKind.Utc);
        student.CPF = Form.CPF.Trim();
        student.Phone = Form.Phone.Trim();
        student.Email = string.IsNullOrWhiteSpace(Form.Email) ? null : Form.Email.Trim();
        student.Address = string.IsNullOrWhiteSpace(Form.Address) ? null : Form.Address.Trim();
        student.Status = Form.Status;
        student.AdmissionDate = DateTime.SpecifyKind(Form.AdmissionDate, DateTimeKind.Utc);
        student.UpdatedAt = DateTime.UtcNow;

        await db.SaveChangesAsync();

        Message = "Dados do aluno atualizados.";

        await LoadStudent();
    }

    private static string GetStatusLabel(int status)
    {
        return status switch
        {
            1 => "Ativo",
            2 => "Inativo",
            3 => "Em acompanhamento",
            4 => "Concluído",
            _ => "Não informado"
        };
    }

    private sealed class StudentForm
    {
        public string FullName { get; set; } = string.Empty;
        public DateTime BirthDate { get; set; } = DateTime.Today.AddYears(-18);
        public string CPF { get; set; } = string.Empty;
        public string Phone { get; set; } = string.Empty;
        public string? Email { get; set; }
        public string? Address { get; set; }
        public int Status { get; set; } = 1;
        public DateTime AdmissionDate { get; set; } = DateTime.Today;
    }
}