@page "/students"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using Renova.Domain.Entities
@using Renova.Infrastructure.Data
@using Renova.Infrastructure.Identity

@attribute [Authorize(Roles = ApplicationRoles.StudentManagementRoles)]

@inject IDbContextFactory<AppDbContext> DbFactory

<PageTitle>Alunos</PageTitle>

<section class="page-header compact">
    <div>
        <p class="eyebrow">CRM</p>
        <h1>Alunos</h1>
        <p>Cadastro básico para validar o fluxo principal do sistema.</p>
    </div>
</section>

<div class="split-grid">
    <div class="form-panel">
        <h2>Novo aluno</h2>

        @if (!string.IsNullOrWhiteSpace(Message))
        {
            <div class="alert alert-success">@Message</div>
        }

        <EditForm Model="Form" OnValidSubmit="SaveStudent">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <label>Nome completo</label>
            <InputText class="form-control" @bind-Value="Form.FullName" />

            <label>Nascimento</label>
            <InputDate class="form-control" @bind-Value="Form.BirthDate" />

            <label>CPF</label>
            <InputText class="form-control" @bind-Value="Form.CPF" />

            <label>Telefone</label>
            <InputText class="form-control" @bind-Value="Form.Phone" />

            <label>Email</label>
            <InputText class="form-control" @bind-Value="Form.Email" />

            <label>Endereço</label>
            <InputText class="form-control" @bind-Value="Form.Address" />

            <label>Status</label>
            <InputSelect class="form-control" @bind-Value="Form.Status">
                <option value="1">Ativo</option>
                <option value="2">Inativo</option>
                <option value="3">Em acompanhamento</option>
                <option value="4">Concluído</option>
            </InputSelect>

            <label>Admissão</label>
            <InputDate class="form-control" @bind-Value="Form.AdmissionDate" />

            <button class="btn btn-primary" type="submit">Salvar aluno</button>
        </EditForm>
    </div>

    <div class="data-panel">
        <div class="panel-title">
            <h2>Alunos cadastrados</h2>
            <button class="btn btn-sm btn-outline-secondary" @onclick="LoadStudents">Atualizar</button>
        </div>

        <div class="mb-3">
            <label>Buscar aluno</label>
            <div class="input-group">
                <input class="form-control"
                       placeholder="Nome, CPF, telefone ou e-mail"
                       @bind="SearchTerm"
                       @bind:event="oninput" />

                <button class="btn btn-outline-primary" @onclick="LoadStudents">
                    Buscar
                </button>
            </div>
        </div>

        <p class="muted">
            Total encontrado: @StudentList.Count
        </p>

        @if (StudentList.Count == 0)
        {
            <p class="muted">Nenhum aluno cadastrado.</p>
        }
        else
        {
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>CPF</th>
                        <th>Telefone</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in StudentList)
                    {
                        <tr>
                            <td>@student.FullName</td>
                            <td>@student.CPF</td>
                            <td>@student.Phone</td>
                            <td>@GetStatusLabel(student.Status)</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" href="@($"students/{student.Id}")">
                                    Abrir
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private List<Student> StudentList { get; set; } = new();
    private StudentForm Form { get; set; } = new();
    private string SearchTerm { get; set; } = string.Empty;
    private string? Message;

    protected override async Task OnInitializedAsync()
    {
        await LoadStudents();
    }

    private async Task LoadStudents()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        var query = db.Students.AsQueryable();

        if (!string.IsNullOrWhiteSpace(SearchTerm))
        {
            var term = SearchTerm.Trim().ToLower();

            query = query.Where(student =>
                student.FullName.ToLower().Contains(term) ||
                student.CPF.ToLower().Contains(term) ||
                student.Phone.ToLower().Contains(term) ||
                (student.Email != null && student.Email.ToLower().Contains(term)));
        }

        StudentList = await query
            .OrderBy(student => student.FullName)
            .ToListAsync();
    }

    private async Task SaveStudent()
    {
        var student = new Student
        {
            FullName = Form.FullName.Trim(),
            BirthDate = DateTime.SpecifyKind(Form.BirthDate, DateTimeKind.Utc),
            CPF = Form.CPF.Trim(),
            Phone = Form.Phone.Trim(),
            Email = string.IsNullOrWhiteSpace(Form.Email) ? null : Form.Email.Trim(),
            Address = string.IsNullOrWhiteSpace(Form.Address) ? null : Form.Address.Trim(),
            Status = Form.Status,
            AdmissionDate = DateTime.SpecifyKind(Form.AdmissionDate, DateTimeKind.Utc),
            CreatedAt = DateTime.UtcNow
        };

        await using var db = await DbFactory.CreateDbContextAsync();

        db.Students.Add(student);
        await db.SaveChangesAsync();

        Form = new();
        Message = "Aluno cadastrado.";

        await LoadStudents();
    }

    private static string GetStatusLabel(int status)
    {
        return status switch
        {
            1 => "Ativo",
            2 => "Inativo",
            3 => "Em acompanhamento",
            4 => "Concluído",
            _ => "Não informado"
        };
    }

    private sealed class StudentForm
    {
        public string FullName { get; set; } = string.Empty;
        public DateTime BirthDate { get; set; } = DateTime.Today.AddYears(-18);
        public string CPF { get; set; } = string.Empty;
        public string Phone { get; set; } = string.Empty;
        public string? Email { get; set; }
        public string? Address { get; set; }
        public int Status { get; set; } = 1;
        public DateTime AdmissionDate { get; set; } = DateTime.Today;
    }
}