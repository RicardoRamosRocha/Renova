@page "/users"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@attribute [Authorize(Roles = ApplicationRoles.UserManagementRoles)]
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject UserSession Session

<PageTitle>Usuarios</PageTitle>

<section class="page-header compact">
    <div>
        <p class="eyebrow">Acesso</p>
        <h1>Usuarios e perfis</h1>
        <p>Crie acessos para administradores, equipe, alunos e familiares.</p>
    </div>
</section>

@if (!Session.IsAuthenticated)
{
    <div class="alert alert-warning">Faca login para acessar usuarios.</div>
    <a class="btn btn-primary" href="login">Entrar</a>
}
else if (!Session.CanManageUsers)
{
    <div class="alert alert-warning">Somente administradores podem gerenciar usuarios.</div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <div class="alert @MessageClass">@Message</div>
    }

    <div class="split-grid">
        <div class="form-panel">
            <h2>Novo usuario</h2>
            <EditForm Model="Form" OnValidSubmit="CreateUser">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <label>Nome completo</label>
                <InputText class="form-control" @bind-Value="Form.FullName" />

                <label>Email</label>
                <InputText class="form-control" @bind-Value="Form.Email" />

                <label>Telefone</label>
                <InputText class="form-control" @bind-Value="Form.PhoneNumber" />

                <label>Perfil</label>
                <InputSelect class="form-select" @bind-Value="Form.Role">
                    @foreach (var role in ApplicationRoles.All)
                    {
                        <option value="@role">@role</option>
                    }
                </InputSelect>

                <label>Senha inicial</label>
                <InputText class="form-control" type="password" @bind-Value="Form.Password" />

                <label class="checkbox-line">
                    <InputCheckbox class="form-check-input" @bind-Value="Form.IsActive" />
                    Usuario ativo
                </label>

                <button class="btn btn-primary" type="submit">Criar usuario</button>
            </EditForm>
        </div>

        <div class="data-panel">
            <div class="panel-title">
                <h2>Usuarios cadastrados</h2>
                <button class="btn btn-sm btn-outline-secondary" @onclick="LoadUsers">Atualizar</button>
            </div>

            @if (UserList.Count == 0)
            {
                <p class="muted">Nenhum usuario cadastrado.</p>
            }
            else
            {
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>Email</th>
                            <th>Perfil</th>
                            <th>Status</th>
                            <th>Nova senha</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in UserList)
                        {
                            <tr>
                                <td>
                                    <input class="form-control" @bind="user.FullName" />
                                </td>
                                <td>
                                    <input class="form-control" type="email" @bind="user.Email" />
                                    <input class="form-control" @bind="user.PhoneNumber" />
                                </td>
                                <td>
                                    <select class="form-select" @bind="user.SelectedRole">
                                        @foreach (var role in ApplicationRoles.All)
                                        {
                                            <option value="@role">@role</option>
                                        }
                                    </select>
                                </td>
                                <td>
                                    <span class="status-pill @(user.IsActive ? "active" : "inactive")">
                                        @(user.IsActive ? "Ativo" : "Inativo")
                                    </span>
                                </td>
                                <td>
                                    <input class="form-control" type="password" @bind="user.NewPassword" />
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary" type="button" @onclick="() => SaveUser(user)">Salvar</button>
                                    <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="() => ToggleUserStatus(user)">
                                        @(user.IsActive ? "Desativar" : "Ativar")
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@code {
    private List<UserRow> UserList { get; set; } = [];
    private UserForm Form { get; set; } = new();
    private string? Message;
    private string MessageClass = "alert-success";

    protected override async Task OnInitializedAsync()
    {
        if (Session.IsAuthenticated && Session.CanManageUsers)
        {
            await EnsureRoles();
            await LoadUsers();
        }
    }

    private async Task LoadUsers()
    {
        var users = await UserManager.Users
            .OrderBy(user => user.FullName)
            .ToListAsync();

        var rows = new List<UserRow>();

        foreach (var user in users)
        {
            var roles = await UserManager.GetRolesAsync(user);
            rows.Add(new UserRow
            {
                Id = user.Id,
                FullName = user.FullName,
                Email = user.Email ?? string.Empty,
                PhoneNumber = user.PhoneNumber ?? string.Empty,
                IsActive = user.IsActive,
                SelectedRole = roles.FirstOrDefault() ?? ApplicationRoles.Attendant
            });
        }

        UserList = rows;
    }

    private async Task CreateUser()
    {
        await EnsureRoles();

        var user = new ApplicationUser
        {
            FullName = Form.FullName.Trim(),
            UserName = Form.Email.Trim(),
            Email = Form.Email.Trim(),
            PhoneNumber = Form.PhoneNumber.Trim(),
            EmailConfirmed = true,
            IsActive = Form.IsActive,
            CreatedAt = DateTime.UtcNow
        };

        var result = await UserManager.CreateAsync(user, Form.Password);

        if (!result.Succeeded)
        {
            ShowError(string.Join(" ", result.Errors.Select(error => error.Description)));
            return;
        }

        await UserManager.AddToRoleAsync(user, Form.Role);
        Form = new();
        ShowSuccess("Usuario criado.");
        await LoadUsers();
    }

    private async Task SaveUser(UserRow row)
    {
        var user = await UserManager.FindByIdAsync(row.Id);

        if (user is null)
        {
            ShowError("Usuario nao encontrado.");
            await LoadUsers();
            return;
        }

        if (string.IsNullOrWhiteSpace(row.FullName) ||
            string.IsNullOrWhiteSpace(row.Email))
        {
            ShowError("Informe nome e email.");
            return;
        }

        var email = row.Email.Trim();
        var existingUser = await UserManager.FindByEmailAsync(email);

        if (existingUser is not null && existingUser.Id != user.Id)
        {
            ShowError("Ja existe outro usuario com este email.");
            await LoadUsers();
            return;
        }

        if (!ApplicationRoles.All.Contains(row.SelectedRole, StringComparer.OrdinalIgnoreCase))
        {
            ShowError("Perfil invalido.");
            return;
        }

        if (row.Id == Session.User?.Id &&
            !ApplicationRoles.UserManagement.Contains(row.SelectedRole, StringComparer.OrdinalIgnoreCase))
        {
            ShowError("Voce nao pode remover seu proprio acesso administrativo.");
            await LoadUsers();
            return;
        }

        await EnsureRoles();

        var currentRoles = await UserManager.GetRolesAsync(user);

        if (!currentRoles.Contains(row.SelectedRole, StringComparer.OrdinalIgnoreCase))
        {
            var roleResult = await UserManager.AddToRoleAsync(user, row.SelectedRole);

            if (!roleResult.Succeeded)
            {
                ShowError(string.Join(" ", roleResult.Errors.Select(error => error.Description)));
                return;
            }
        }

        var rolesToRemove = currentRoles
            .Where(role => !role.Equals(row.SelectedRole, StringComparison.OrdinalIgnoreCase))
            .ToArray();

        if (rolesToRemove.Length > 0)
        {
            var removeResult = await UserManager.RemoveFromRolesAsync(user, rolesToRemove);

            if (!removeResult.Succeeded)
            {
                ShowError(string.Join(" ", removeResult.Errors.Select(error => error.Description)));
                return;
            }
        }

        user.FullName = row.FullName.Trim();
        user.UserName = email;
        user.Email = email;
        user.PhoneNumber = row.PhoneNumber.Trim();
        user.EmailConfirmed = true;

        if (!string.IsNullOrWhiteSpace(row.NewPassword))
        {
            var passwordResult = await ReplacePassword(user, row.NewPassword);

            if (!passwordResult.Succeeded)
            {
                ShowError(string.Join(" ", passwordResult.Errors.Select(error => error.Description)));
                return;
            }
        }

        user.UpdatedAt = DateTime.UtcNow;
        var updateResult = await UserManager.UpdateAsync(user);

        if (!updateResult.Succeeded)
        {
            ShowError(string.Join(" ", updateResult.Errors.Select(error => error.Description)));
            return;
        }

        ShowSuccess("Usuario atualizado.");
        await LoadUsers();
    }

    private async Task<IdentityResult> ReplacePassword(ApplicationUser user, string newPassword)
    {
        if (await UserManager.HasPasswordAsync(user))
        {
            var removeResult = await UserManager.RemovePasswordAsync(user);

            if (!removeResult.Succeeded)
            {
                return removeResult;
            }
        }

        return await UserManager.AddPasswordAsync(user, newPassword);
    }

    private async Task ToggleUserStatus(UserRow row)
    {
        var user = await UserManager.FindByIdAsync(row.Id);

        if (user is null)
        {
            ShowError("Usuario nao encontrado.");
            await LoadUsers();
            return;
        }

        if (row.Id == Session.User?.Id && user.IsActive)
        {
            ShowError("Voce nao pode desativar seu proprio usuario.");
            return;
        }

        user.IsActive = !user.IsActive;
        user.UpdatedAt = DateTime.UtcNow;

        var result = await UserManager.UpdateAsync(user);

        if (!result.Succeeded)
        {
            ShowError(string.Join(" ", result.Errors.Select(error => error.Description)));
            return;
        }

        ShowSuccess(user.IsActive ? "Usuario ativado." : "Usuario desativado.");
        await LoadUsers();
    }

    private async Task EnsureRoles()
    {
        foreach (var roleName in ApplicationRoles.All)
        {
            if (!await RoleManager.RoleExistsAsync(roleName))
            {
                await RoleManager.CreateAsync(new IdentityRole(roleName));
            }
        }
    }

    private void ShowSuccess(string message)
    {
        Message = message;
        MessageClass = "alert-success";
    }

    private void ShowError(string message)
    {
        Message = message;
        MessageClass = "alert-danger";
    }

    private sealed class UserForm
    {
        public string FullName { get; set; } = string.Empty;

        public string Email { get; set; } = string.Empty;

        public string PhoneNumber { get; set; } = string.Empty;

        public string Role { get; set; } = ApplicationRoles.Attendant;

        public string Password { get; set; } = string.Empty;

        public bool IsActive { get; set; } = true;
    }

    private sealed class UserRow
    {
        public string Id { get; set; } = string.Empty;

        public string FullName { get; set; } = string.Empty;

        public string Email { get; set; } = string.Empty;

        public string PhoneNumber { get; set; } = string.Empty;

        public string SelectedRole { get; set; } = ApplicationRoles.Attendant;

        public bool IsActive { get; set; }

        public string? NewPassword { get; set; }
    }
}
