@using Renova.Domain.Entities
@using Renova.Web.ViewModels
@model Professional
@{
    ViewData["Title"] = "Detalhes do Profissional";
    var displayName = Model.DisplayName;
}

<section class="admin-page">
    <div class="demo-profile-hero">
        @await Html.PartialAsync("~/Views/Shared/_ProfileAvatar.cshtml", new ProfileAvatarViewModel
        {
            Name = displayName,
            PhotoUrl = Model.DisplayPhotoUrl,
            Size = "lg"
        })
        <div>
            <span class="rn-eyebrow">Profissional</span>
            <h1>@displayName</h1>
            <p>
                <span class="renova-status-badge @(Model.IsActive ? "ok" : "danger")">@(Model.IsActive ? "Ativo" : "Inativo")</span>
                @Model.Specialty
            </p>
        </div>
        <a class="rn-btn-primary" asp-action="Edit" asp-route-id="@Model.Id"><i class="ph ph-pencil-simple" aria-hidden="true"></i>Editar</a>
    </div>
    <div class="demo-profile-meta">
        <article><small>Registro</small><strong>@Model.RegistrationNumber</strong></article>
        <article><small>Telefone</small><strong>@Model.DisplayPhone</strong></article>
        <article><small>Email</small><strong>@(Model.DisplayEmail ?? "Não informado")</strong></article>
        <article><small>Criado em</small><strong>@Model.CreatedAt.ToString("dd/MM/yyyy")</strong></article>
    </div>
</section>
