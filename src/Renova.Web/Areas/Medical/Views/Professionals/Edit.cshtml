@using Renova.Web.Areas.Medical.ViewModels.Professionals
@model ProfessionalFormViewModel
@{
    ViewData["Title"] = "Editar Profissional";
}

<section class="admin-form-page">
    <header class="admin-form-header">
        <div>
            <nav class="admin-form-breadcrumb"><a asp-action="Index">Profissionais</a><span>/</span><span>Editar cadastro</span></nav>
            <span class="rn-eyebrow">Equipe</span>
            <h1>Editar Profissional</h1>
            <p>Atualize identificação, registro profissional, especialidade e canais de contato.</p>
        </div>
        <a class="rn-btn-secondary" asp-action="Index"><i class="ph ph-arrow-left" aria-hidden="true"></i>Voltar</a>
    </header>
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @await Html.PartialAsync("_Form", Model)
    </form>
</section>
