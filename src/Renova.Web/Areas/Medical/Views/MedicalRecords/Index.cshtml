@{
    ViewData["Title"] = "Prontuário";
}

<section class="demo-page">
    <div class="demo-hero">
        <div>
            <span class="demo-kicker">Prontuário eletrônico</span>
            <h1>João Silva</h1>
            <p>Registro clínico consolidado com dados gerais, evoluções, medicações, atendimentos, documentos e anexos.</p>
        </div>
        <span class="demo-pill ok">Plano ativo</span>
    </div>

    <section class="demo-panel demo-tabs">
        <div class="demo-tab-list" aria-label="Abas do prontuário">
            <span>Dados Gerais</span>
            <span>Evoluções</span>
            <span>Medicações</span>
            <span>Atendimentos</span>
            <span>Documentos</span>
            <span>Anexos</span>
        </div>

        <div class="demo-grid-3">
            <article class="demo-card"><span>Tempo em tratamento</span><strong>128 dias</strong><small>Fase intermediária</small></article>
            <article class="demo-card"><span>Última evolução</span><strong>02/07</strong><small>Psicologia</small></article>
            <article class="demo-card"><span>Risco clínico</span><strong>Baixo</strong><small>Monitorado</small></article>
        </div>

        <div class="demo-grid-2">
            <section class="demo-panel">
                <div class="demo-section-title"><h2>Dados Gerais</h2></div>
                <div class="demo-mini-list">
                    <span>Nascimento <strong>14/09/1991</strong></span>
                    <span>Responsável <strong>Helena Silva</strong></span>
                    <span>Unidade <strong>Centro</strong></span>
                    <span>Plano terapêutico <strong>Integral</strong></span>
                </div>
            </section>
            <section class="demo-panel">
                <div class="demo-section-title"><h2>Evoluções recentes</h2></div>
                <div class="demo-list">
                    <article class="demo-list-item"><strong>Psicologia</strong><span>Adesão consistente e participação ativa.</span></article>
                    <article class="demo-list-item"><strong>Enfermagem</strong><span>Rotina medicamentosa sem intercorrências.</span></article>
                    <article class="demo-list-item"><strong>Serviço social</strong><span>Família orientada para plano de reintegração.</span></article>
                </div>
            </section>
        </div>
    </section>
</section>
