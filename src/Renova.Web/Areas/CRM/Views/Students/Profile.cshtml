@{
    ViewData["Title"] = "Perfil do Acolhido";
}

<section class="demo-page">
    <div class="demo-profile-hero">
        <span class="demo-photo">JS</span>
        <div>
            <span class="demo-kicker">Perfil do acolhido</span>
            <h1>João Silva</h1>
            <p><span class="demo-pill ok">Em tratamento</span> 128 dias de acompanhamento · Unidade Centro</p>
        </div>
        <a class="demo-button-secondary" asp-action="Index">Voltar</a>
    </div>

    <div class="demo-profile-meta">
        <article><small>Instituição</small><strong>Renova Unidade Centro</strong></article>
        <article><small>Responsável</small><strong>Helena Silva</strong></article>
        <article><small>Telefone</small><strong>(11) 98422-1030</strong></article>
        <article><small>Plano</small><strong>Integral Premium</strong></article>
    </div>

    <div class="demo-profile-grid">
        <aside class="demo-side-stack">
            <section class="demo-panel">
                <div class="demo-section-title"><h2>Histórico</h2></div>
                <p class="demo-muted">Entrada em 26/02, plano terapêutico revisado quinzenalmente, evolução consistente em rotina, vínculos familiares e participação no EAD.</p>
            </section>
            <section class="demo-panel">
                <div class="demo-section-title"><h2>Próxima consulta</h2></div>
                <strong>03/07 às 08:00</strong>
                <p class="demo-muted">Psicoterapia individual com Dra. Camila Torres.</p>
            </section>
            <section class="demo-panel">
                <div class="demo-section-title"><h2>Cursos realizados</h2></div>
                <div class="demo-mini-list">
                    <span>Prevenção de recaídas <strong>92%</strong></span>
                    <span>Projeto de vida <strong>84%</strong></span>
                    <span>Comunicação familiar <strong>76%</strong></span>
                </div>
            </section>
        </aside>

        <div class="demo-side-stack">
            <section class="demo-panel">
                <div class="demo-section-title">
                    <div><span class="demo-kicker">Clínico</span><h2>Últimos atendimentos</h2></div>
                </div>
                <div class="demo-list">
                    <article class="demo-list-item"><strong>Psicologia individual</strong><span>02/07 · Evolução positiva</span></article>
                    <article class="demo-list-item"><strong>Terapia em grupo</strong><span>01/07 · Participação ativa</span></article>
                    <article class="demo-list-item"><strong>Atendimento familiar</strong><span>28/06 · Vínculo fortalecido</span></article>
                </div>
            </section>

            <section class="demo-panel">
                <div class="demo-section-title"><h2>Evoluções</h2></div>
                <div class="demo-grid-3">
                    <article class="demo-card"><span>Adesão ao plano</span><strong>88%</strong><small>Excelente</small></article>
                    <article class="demo-card"><span>Rotina terapêutica</span><strong>91%</strong><small>Estável</small></article>
                    <article class="demo-card"><span>Risco de evasão</span><strong>Baixo</strong><small>Monitorado</small></article>
                </div>
            </section>

            <section class="demo-panel">
                <div class="demo-section-title"><h2>Linha do tempo da recuperação</h2></div>
                <div class="demo-timeline">
                    <article class="demo-timeline-item"><strong>Semana 1</strong><p>Acolhimento, avaliação inicial e definição do plano terapêutico.</p></article>
                    <article class="demo-timeline-item"><strong>Dia 30</strong><p>Primeira revisão com melhora de sono, rotina e participação em grupos.</p></article>
                    <article class="demo-timeline-item"><strong>Dia 90</strong><p>Início da trilha de reintegração familiar e cursos de projeto de vida.</p></article>
                    <article class="demo-timeline-item"><strong>Hoje</strong><p>Alta prevista em 42 dias com acompanhamento intensivo de reinserção.</p></article>
                </div>
            </section>
        </div>
    </div>
</section>
