@using Renova.Domain.Entities
@using Renova.Web.Areas.CRM.ViewModels.Students
@using Renova.Web.ViewModels
@model StudentIndexViewModel

@{
    ViewData["Title"] = "Acolhidos";
    var statuses = Model.Statuses;
}

<section class="crm-index-page">
    <div class="crm-page-header">
        <div>
            <span class="crm-eyebrow">CRM / Acolhidos</span>
            <h1>Acolhidos</h1>
            <p>Gerencie cadastros, admissões, vínculos familiares e acesso rápido ao perfil dos acolhidos.</p>
        </div>

        <a class="crm-primary-button" asp-action="Create">
            <i class="ph ph-user-plus" aria-hidden="true"></i>
            Novo acolhido
        </a>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="crm-alert-success">
            <i class="ph ph-check-circle" aria-hidden="true"></i>
            <span>@success</span>
        </div>
    }

    <div class="crm-metrics-grid">
        <article class="crm-metric-card">
            <div class="metric-icon">
                <i class="ph ph-users" aria-hidden="true"></i>
            </div>
            <span>Total</span>
            <strong>@Model.Total</strong>
            <small>Acolhidos cadastrados</small>
        </article>

        <article class="crm-metric-card">
            <div class="metric-icon">
                <i class="ph ph-check-circle" aria-hidden="true"></i>
            </div>
            <span>Ativos</span>
            <strong>@Model.Active</strong>
            <small>Em operação</small>
        </article>

        <article class="crm-metric-card">
            <div class="metric-icon">
                <i class="ph ph-heartbeat" aria-hidden="true"></i>
            </div>
            <span>Em tratamento</span>
            <strong>@Model.InTreatment</strong>
            <small>Planos ativos</small>
        </article>

        <article class="crm-metric-card">
            <div class="metric-icon">
                <i class="ph ph-calendar-check" aria-hidden="true"></i>
            </div>
            <span>Altas previstas</span>
            <strong>@Model.DischargePlanned</strong>
            <small>Planejadas no CRM</small>
        </article>
    </div>

    <section class="renova-table-card">
        <div class="renova-table-header">
            <div>
                <span class="crm-eyebrow">Lista</span>
                <h2>Cadastros de acolhidos</h2>
                <p>Visualize os acolhidos, status e ações principais.</p>
            </div>

            <form class="crm-filter-form" method="get">
                <div class="crm-search-box">
                    <i class="ph ph-magnifying-glass" aria-hidden="true"></i>
                    <input name="search"
                           value="@Model.Search"
                           type="search"
                           placeholder="Buscar por nome, CPF, telefone ou email" />
                </div>

                <select name="status">
                    <option value="">Todos os status</option>
                    @foreach (var status in statuses)
                    {
                        <option value="@status.Key" selected="@(Model.Status == status.Key)">
                            @status.Value
                        </option>
                    }
                </select>

                <input class="admin-input" name="admissionFrom" value="@Model.AdmissionFrom?.ToString("yyyy-MM-dd")" type="date" />
                <input class="admin-input" name="admissionTo" value="@Model.AdmissionTo?.ToString("yyyy-MM-dd")" type="date" />

                <button class="crm-secondary-button" type="submit">
                    <i class="ph ph-funnel" aria-hidden="true"></i>
                    Filtrar
                </button>
            </form>
        </div>

        @if (Model.Students.Items.Count == 0)
        {
            <div class="crm-empty-state">
                <div class="crm-empty-icon">
                    <i class="ph ph-users" aria-hidden="true"></i>
                </div>

                <strong>Nenhum acolhido encontrado</strong>
                <p>Cadastre o primeiro acolhido ou ajuste os filtros de busca.</p>

                <a class="crm-primary-button" asp-action="Create">
                    <i class="ph ph-user-plus" aria-hidden="true"></i>
                    Criar primeiro cadastro
                </a>
            </div>
        }
        else
        {
            <div class="renova-table-wrap">
                <table class="renova-table">
                    <thead>
                        <tr>
                            <th>Acolhido</th>
                            <th>CPF</th>
                            <th>Telefone</th>
                            <th>Entrada</th>
                            <th>Situação</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var student in Model.Students.Items)
                        {
                            var statusClass = student.Status == StudentStatuses.Inactive
                                ? "danger"
                                : student.Status == StudentStatuses.InTreatment
                                    ? "info"
                                    : student.Status == StudentStatuses.DischargePlanned
                                        ? "warn"
                                        : "ok";

                            <tr>
                                <td>
                                    <a class="renova-person-cell" asp-action="Details" asp-route-id="@student.Id">
                                        @await Html.PartialAsync("~/Views/Shared/_ProfileAvatar.cshtml", new ProfileAvatarViewModel
                                        {
                                            Name = student.Name,
                                            PhotoUrl = student.PhotoUrl
                                        })

                                        <span>
                                            <strong class="renova-row-title">@student.Name</strong>
                                            <small class="renova-row-subtitle">@StudentStatuses.Label(student.Status)</small>
                                        </span>
                                    </a>
                                </td>

                                <td>
                                    <span class="renova-muted">@student.Cpf</span>
                                </td>

                                <td>
                                    <span class="renova-muted">@student.Phone</span>
                                </td>

                                <td>
                                    <span class="renova-muted">@student.AdmissionDate.ToString("dd/MM/yyyy")</span>
                                    @if (!string.IsNullOrWhiteSpace(student.ResponsibleProfessional))
                                    {
                                        <small class="renova-row-subtitle">Resp. @student.ResponsibleProfessional</small>
                                    }
                                </td>

                                <td>
                                    <span class="renova-status-badge @statusClass">
                                        @StudentStatuses.Label(student.Status)
                                    </span>
                                </td>

                                <td>
                                    <div class="renova-action-buttons">
                                        <a class="renova-action-btn"
                                           title="Detalhes"
                                           asp-action="Details"
                                           asp-route-id="@student.Id">
                                            <i class="ph ph-eye" aria-hidden="true"></i>
                                        </a>

                                        <a class="renova-action-btn"
                                           title="Editar"
                                           asp-action="Edit"
                                           asp-route-id="@student.Id">
                                            <i class="ph ph-pencil-simple" aria-hidden="true"></i>
                                        </a>

                                        <a class="renova-action-btn danger"
                                           title="Arquivar"
                                           href="#delete-student-@student.Id">
                                            <i class="ph ph-archive" aria-hidden="true"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @await Html.PartialAsync("~/Views/Shared/_Pagination.cshtml", Model.Students)

            @foreach (var student in Model.Students.Items)
            {
                <div id="delete-student-@student.Id" class="admin-delete-modal" role="dialog" aria-modal="true">
                    <div class="admin-delete-dialog">
                        <h2>Arquivar acolhido</h2>
                        <p>Deseja realmente arquivar este registro? Se houver vínculos, o acolhido será inativado com segurança.</p>

                        <div class="admin-delete-actions">
                            <a class="admin-button-secondary" href="#">Cancelar</a>

                            <form asp-action="Delete" asp-route-id="@student.Id" method="post">
                                <button class="admin-action-button danger" type="submit">
                                    Arquivar
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
    </section>
</section>
