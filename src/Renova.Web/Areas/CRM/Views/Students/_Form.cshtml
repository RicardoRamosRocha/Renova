@using Renova.Web.Areas.CRM.ViewModels.Students
@model StudentFormViewModel
@{
    var isEdit = Model.Id.HasValue;
}

<input type="hidden" asp-for="Id" />
<div asp-validation-summary="ModelOnly" class="admin-validation-summary"></div>

<div class="admin-form-card">
    <section class="admin-form-section">
        <div class="admin-form-section-title">
            <div>
                <span class="demo-kicker">Dados pessoais</span>
                <h2>Identificação do acolhido</h2>
                <p>Informações básicas para localizar e acompanhar o acolhido no CRM.</p>
            </div>
        </div>
        <div class="admin-form-grid three">
            <div class="admin-form-group">
                <label class="admin-label required" asp-for="FullName">Nome completo</label>
                <input class="admin-input" asp-for="FullName" autocomplete="name" />
                <span class="admin-validation" asp-validation-for="FullName"></span>
            </div>
            <div class="admin-form-group">
                <label class="admin-label required" asp-for="CPF">CPF</label>
                <input class="admin-input" asp-for="CPF" inputmode="numeric" />
                <span class="admin-validation" asp-validation-for="CPF"></span>
            </div>
            <div class="admin-form-group">
                <label class="admin-label" asp-for="RG">RG</label>
                <input class="admin-input" asp-for="RG" />
                <span class="admin-validation" asp-validation-for="RG"></span>
            </div>
            <div class="admin-form-group">
                <label class="admin-label required" asp-for="BirthDate">Data de nascimento</label>
                <input class="admin-input" asp-for="BirthDate" type="date" />
                <span class="admin-validation" asp-validation-for="BirthDate"></span>
            </div>
            <div class="admin-form-group">
                <label class="admin-label required" asp-for="Status">Status</label>
                <select class="admin-select" asp-for="Status">
                    @foreach (var status in StudentStatuses.Labels)
                    {
                        <option value="@status.Key">@status.Value</option>
                    }
                </select>
                <span class="admin-validation" asp-validation-for="Status"></span>
            </div>
        </div>
    </section>

    <section class="admin-form-section">
        <div class="admin-form-section-title">
            <div>
                <span class="demo-kicker">Contato</span>
                <h2>Canais de comunicação</h2>
                <p>Telefones e email usados pela equipe para contato rápido.</p>
            </div>
        </div>
        <div class="admin-form-grid three">
            <div class="admin-form-group">
                <label class="admin-label required" asp-for="Phone">Telefone</label>
                <input class="admin-input" asp-for="Phone" inputmode="tel" autocomplete="tel" />
                <span class="admin-validation" asp-validation-for="Phone"></span>
            </div>
            <div class="admin-form-group">
                <label class="admin-label" asp-for="WhatsApp">WhatsApp</label>
                <input class="admin-input" asp-for="WhatsApp" inputmode="tel" />
                <span class="admin-validation" asp-validation-for="WhatsApp"></span>
            </div>
            <div class="admin-form-group">
                <label class="admin-label" asp-for="Email">Email</label>
                <input class="admin-input" asp-for="Email" autocomplete="email" />
                <span class="admin-validation" asp-validation-for="Email"></span>
            </div>
        </div>
    </section>

    <section class="admin-form-section">
        <div class="admin-form-section-title">
            <div>
                <span class="demo-kicker">Endereço</span>
                <h2>Localização</h2>
                <p>Endereço completo para cadastro institucional.</p>
            </div>
        </div>
        <div class="admin-form-grid">
            <div class="admin-form-group-full">
                <label class="admin-label" asp-for="Address">Endereço completo</label>
                <input class="admin-input" asp-for="Address" autocomplete="street-address" />
                <span class="admin-validation" asp-validation-for="Address"></span>
            </div>
        </div>
    </section>

    <section class="admin-form-section">
        <div class="admin-form-section-title">
            <div>
                <span class="demo-kicker">Acolhimento</span>
                <h2>Informações do acompanhamento</h2>
                <p>Dados operacionais para início e histórico do tratamento.</p>
            </div>
        </div>
        <div class="admin-form-grid">
            <div class="admin-form-group">
                <label class="admin-label required" asp-for="AdmissionDate">Data de entrada</label>
                <input class="admin-input" asp-for="AdmissionDate" type="date" />
                <span class="admin-validation" asp-validation-for="AdmissionDate"></span>
            </div>
            <div class="admin-form-group-full">
                <label class="admin-label" asp-for="Notes">Observações</label>
                <textarea class="admin-textarea" asp-for="Notes"></textarea>
                <span class="admin-help-text">Campo visual para apoio à demonstração. Não altera o modelo de domínio atual.</span>
                <span class="admin-validation" asp-validation-for="Notes"></span>
            </div>
        </div>
    </section>

    <div class="admin-form-actions">
        <a class="admin-button-secondary" asp-action="Index">Cancelar</a>
        <button class="admin-button-primary" type="submit">@(isEdit ? "Salvar alterações" : "Cadastrar acolhido")</button>
    </div>
</div>
