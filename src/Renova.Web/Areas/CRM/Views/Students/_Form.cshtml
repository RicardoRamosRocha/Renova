@using Renova.Web.Areas.CRM.ViewModels.Students
@model StudentFormViewModel

@{
    var isEdit = Model.Id.HasValue;
}

<input type="hidden" asp-for="Id" />
<input type="hidden" asp-for="PhotoPath" />

<div asp-validation-summary="ModelOnly" class="admin-validation-summary"></div>

<div class="premium-form-card">
    <div class="premium-form-header">
        <h2>@(isEdit ? "Editar acolhido" : "Novo acolhido")</h2>
        <p>Preencha as informações principais do acolhido para cadastro e acompanhamento.</p>
    </div>

    <div class="premium-form-body">

        <div class="form-section-title">
            <i class="bi bi-person"></i>
            <span>Dados pessoais</span>
        </div>

        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label" asp-for="FullName">Nome completo</label>
                <input class="form-control" asp-for="FullName" autocomplete="name" placeholder="Digite o nome completo" />
                <span class="text-danger" asp-validation-for="FullName"></span>
            </div>

            <div class="col-md-3">
                <label class="form-label" asp-for="CPF">CPF</label>
                <input class="form-control" asp-for="CPF" inputmode="numeric" placeholder="000.000.000-00" />
                <span class="text-danger" asp-validation-for="CPF"></span>
            </div>

            <div class="col-md-3">
                <label class="form-label" asp-for="RG">RG</label>
                <input class="form-control" asp-for="RG" placeholder="Digite o RG" />
                <span class="text-danger" asp-validation-for="RG"></span>
            </div>

            <div class="col-md-4">
                <label class="form-label" asp-for="BirthDate">Data de nascimento</label>
                <input class="form-control" asp-for="BirthDate" type="date" />
                <span class="text-danger" asp-validation-for="BirthDate"></span>
            </div>

            <div class="col-md-4">
                <label class="form-label" asp-for="Status">Status</label>
                <select class="form-select" asp-for="Status">
                    @foreach (var status in StudentStatuses.Labels)
                    {
                        <option value="@status.Key">@status.Value</option>
                    }
                </select>
                <span class="text-danger" asp-validation-for="Status"></span>
            </div>
        </div>

        <hr class="divider-soft" />

        <div class="form-section-title">
            <i class="bi bi-telephone"></i>
            <span>Contato</span>
        </div>

        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label" asp-for="Phone">Telefone</label>
                <input class="form-control" asp-for="Phone" inputmode="tel" autocomplete="tel" placeholder="(00) 00000-0000" />
                <span class="text-danger" asp-validation-for="Phone"></span>
            </div>

            <div class="col-md-4">
                <label class="form-label" asp-for="WhatsApp">WhatsApp</label>
                <input class="form-control" asp-for="WhatsApp" inputmode="tel" placeholder="(00) 00000-0000" />
                <span class="text-danger" asp-validation-for="WhatsApp"></span>
            </div>

            <div class="col-md-4">
                <label class="form-label" asp-for="Email">Email</label>
                <input class="form-control" asp-for="Email" autocomplete="email" placeholder="email@exemplo.com" />
                <span class="text-danger" asp-validation-for="Email"></span>
            </div>
        </div>

        <hr class="divider-soft" />

        <div class="form-section-title">
            <i class="bi bi-geo-alt"></i>
            <span>Endereço</span>
        </div>

        <div class="row g-3">
            <div class="col-12">
                <label class="form-label" asp-for="Address">Endereço completo</label>
                <input class="form-control" asp-for="Address" autocomplete="street-address" placeholder="Rua, número, bairro, cidade e UF" />
                <span class="text-danger" asp-validation-for="Address"></span>
            </div>
        </div>

        <hr class="divider-soft" />

        <div class="form-section-title">
            <i class="bi bi-heart-pulse"></i>
            <span>Acolhimento</span>
        </div>

        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label" asp-for="AdmissionDate">Data de entrada</label>
                <input class="form-control" asp-for="AdmissionDate" type="date" />
                <span class="text-danger" asp-validation-for="AdmissionDate"></span>
            </div>

            <div class="col-12">
                <label class="form-label" asp-for="Notes">Observações</label>
                <textarea class="form-control" asp-for="Notes" rows="4" placeholder="Registre observações relevantes para a equipe"></textarea>
                <span class="form-hint">Campo visual para apoio à demonstração. Não altera o modelo de domínio atual.</span>
                <span class="text-danger" asp-validation-for="Notes"></span>
            </div>
        </div>
    </div>

    <div class="premium-form-footer">
        <a class="premium-btn" asp-action="Index">
            <i class="bi bi-arrow-left"></i>
            Voltar
        </a>

        <button class="premium-btn premium-btn-primary" type="submit">
            <i class="bi bi-check2-circle"></i>
            @(isEdit ? "Salvar alterações" : "Cadastrar acolhido")
        </button>
    </div>
</div>