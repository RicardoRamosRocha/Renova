@using Renova.Web.Areas.CRM.ViewModels.Students
@using Renova.Web.ViewModels
@model StudentDetailsViewModel
@{
    ViewData["Title"] = "Perfil do Acolhido";
    var statusBadgeClass = Model.Status == StudentStatuses.Inactive
        ? "rn-badge-danger"
        : Model.Status == StudentStatuses.DischargePlanned
            ? "rn-badge-warning"
            : Model.Status == StudentStatuses.InTreatment
                ? "rn-badge-info"
                : "rn-badge-success";
}

<section class="admin-page patient-profile">
    <div class="patient-hero">
        <div class="patient-identity">
            @await Html.PartialAsync("~/Views/Shared/_ProfileAvatar.cshtml", new ProfileAvatarViewModel
            {
                Name = Model.Name,
                PhotoUrl = Model.PhotoUrl,
                Size = "lg"
            })
            <div>
                <span class="rn-eyebrow">CRM / Perfil do acolhido</span>
                <h1>@Model.Name</h1>
                <p>
                    <span class="rn-badge @statusBadgeClass">@StudentStatuses.Label(Model.Status)</span>
                    <span>@Model.TenantName</span>
                    @if (!string.IsNullOrWhiteSpace(Model.ResponsibleProfessional))
                    {
                        <span>Resp. @Model.ResponsibleProfessional</span>
                    }
                </p>
            </div>
        </div>
        <div class="patient-actions">
            <a class="rn-btn-primary" asp-action="Edit" asp-route-id="@Model.Id"><i class="ph ph-pencil-simple" aria-hidden="true"></i>Editar</a>
            <a class="rn-btn-secondary" asp-controller="Admissions" asp-action="Create" asp-route-studentId="@Model.Id"><i class="ph ph-door-open" aria-hidden="true"></i>Admissão</a>
            <a class="rn-btn-secondary" asp-controller="Families" asp-action="Create" asp-route-studentId="@Model.Id"><i class="ph ph-users-three" aria-hidden="true"></i>Familiar</a>
            <a class="rn-btn-secondary" asp-action="Index"><i class="ph ph-arrow-left" aria-hidden="true"></i>Voltar</a>
        </div>
    </div>

    <div class="patient-kpi-grid">
        <article><small>Idade</small><strong>@Model.Age anos</strong></article>
        <article><small>Dias de permanência</small><strong>@Model.TreatmentDays</strong></article>
        <article><small>CPF</small><strong>@Model.Cpf</strong></article>
        <article><small>Entrada</small><strong>@Model.AdmissionDate.ToString("dd/MM/yyyy")</strong></article>
    </div>

    <nav class="crm-profile-tabs" aria-label="Seções do perfil">
        <a href="#overview">Visão geral</a>
        <a href="#admissions">Admissões</a>
        <a href="#family">Família</a>
        <a href="#agenda">Agenda</a>
        <a href="#timeline">Timeline</a>
    </nav>

    <div class="patient-profile-grid" id="overview">
        <section class="patient-card">
            <div class="patient-card-title">
                <span>01</span>
                <div><h2>Dados pessoais</h2><p>Identificação principal do acolhido.</p></div>
            </div>
            <dl class="patient-data-list">
                <div><dt>Nome completo</dt><dd>@Model.Name</dd></div>
                <div><dt>CPF</dt><dd>@Model.Cpf</dd></div>
                <div><dt>Nascimento</dt><dd>@Model.BirthDate.ToString("dd/MM/yyyy")</dd></div>
                <div><dt>Idade</dt><dd>@Model.Age anos</dd></div>
            </dl>
        </section>

        <section class="patient-card">
            <div class="patient-card-title">
                <span>02</span>
                <div><h2>Contato</h2><p>Canais usados pela equipe.</p></div>
            </div>
            <dl class="patient-data-list">
                <div><dt>Telefone</dt><dd>@Model.Phone</dd></div>
                <div><dt>Email</dt><dd>@(Model.Email ?? "Não informado")</dd></div>
                <div><dt>Endereço</dt><dd>@(Model.Address ?? "Não informado")</dd></div>
            </dl>
        </section>

        <section class="patient-card" id="admissions">
            <div class="patient-card-title">
                <span>03</span>
                <div><h2>Admissões</h2><p>Histórico de acolhimentos e altas.</p></div>
            </div>
            <div class="patient-list">
                @if (Model.Admissions.Count == 0)
                {
                    <article><strong>Nenhuma admissão registrada</strong><span>Crie uma admissão para iniciar o histórico operacional.</span></article>
                }
                else
                {
                    @foreach (var admission in Model.Admissions)
                    {
                        <article>
                            <strong>@admission.Status - @admission.AdmissionDate.ToString("dd/MM/yyyy")</strong>
                            <span>
                                @(admission.ResponsibleProfessional ?? "Profissional não informado")
                                @if (admission.ExpectedDischargeDate.HasValue)
                                {
                                    <text> · previsão @admission.ExpectedDischargeDate.Value.ToString("dd/MM/yyyy")</text>
                                }
                            </span>
                        </article>
                    }
                }
            </div>
        </section>

        <section class="patient-card" id="family">
            <div class="patient-card-title">
                <span>04</span>
                <div><h2>Família</h2><p>Rede de apoio vinculada.</p></div>
            </div>
            <div class="patient-list">
                @if (Model.FamilyMembers.Count == 0)
                {
                    <article><strong>Nenhum familiar cadastrado</strong><span>Inclua contatos autorizados para acompanhamento.</span></article>
                }
                else
                {
                    @foreach (var member in Model.FamilyMembers)
                    {
                        <article>
                            <strong>@member.Name</strong>
                            <span>@member.Relationship · @member.Phone</span>
                            <span>
                                @if (member.IsResponsible)
                                {
                                    <span class="rn-badge rn-badge-info">Responsável</span>
                                }
                                @if (member.CanAccessPortal)
                                {
                                    <span class="rn-badge rn-badge-success">Portal</span>
                                }
                            </span>
                        </article>
                    }
                }
            </div>
        </section>

        <section class="patient-card" id="agenda">
            <div class="patient-card-title">
                <span>05</span>
                <div><h2>Agenda</h2><p>Próximos atendimentos reais.</p></div>
            </div>
            <div class="patient-list">
                @if (Model.Appointments.Count == 0)
                {
                    <article><strong>Sem atendimentos futuros</strong><span>Nenhum agendamento encontrado para este acolhido.</span></article>
                }
                else
                {
                    @foreach (var appointment in Model.Appointments)
                    {
                        <article>
                            <strong>@appointment.ScheduledAt.ToString("dd/MM/yyyy HH:mm")</strong>
                            <span>@appointment.ProfessionalName</span>
                        </article>
                    }
                }
            </div>
        </section>

        <section class="patient-card" id="timeline">
            <div class="patient-card-title">
                <span>06</span>
                <div><h2>Timeline</h2><p>Eventos reais consolidados do acolhido.</p></div>
            </div>
            @await Html.PartialAsync("~/Views/Shared/_Timeline.cshtml", Model.Timeline)
        </section>
    </div>
</section>
