@using Renova.Domain.Entities
@using Renova.Web.Areas.CRM.ViewModels.Students
@using Renova.Web.ViewModels
@model Student
@{
    ViewData["Title"] = "Prontuário do Acolhido";
    var today = DateTime.Today;
    var birthDate = Model.DisplayBirthDate.Date;
    var admissionDate = Model.AdmissionDate.Date;
    var age = today.Year - birthDate.Year;
    if (birthDate > today.AddYears(-age))
    {
        age--;
    }

    var treatmentDays = Math.Max(0, (today - admissionDate).Days);
    var statusClass = Model.Status == StudentStatuses.Inactive
        ? "danger"
        : Model.Status == StudentStatuses.InTreatment
            ? "info"
            : Model.Status == StudentStatuses.DischargePlanned
                ? "warn"
                : "ok";
    var statusBadgeClass = statusClass == "ok" ? "rn-badge-success" : statusClass == "warn" ? "rn-badge-warning" : statusClass == "danger" ? "rn-badge-danger" : "rn-badge-info";
    var nextAppointments = Model.Appointments
        .Where(item => item.ScheduledAt.Date >= today)
        .OrderBy(item => item.ScheduledAt)
        .Take(3)
        .ToList();
    var evolutions = Model.MedicalEvolutions
        .Where(item => !item.IsDeleted)
        .OrderByDescending(item => item.CreatedAt)
        .Take(3)
        .ToList();
    var courses = Model.ProgressEntries
        .OrderByDescending(item => item.UpdatedAt ?? item.CreatedAt)
        .Take(3)
        .ToList();
}

<section class="admin-page patient-profile">
    <div class="patient-hero">
        <div class="patient-identity">
            @await Html.PartialAsync("~/Views/Shared/_ProfileAvatar.cshtml", new ProfileAvatarViewModel
            {
                Name = Model.DisplayName,
                PhotoUrl = Model.DisplayPhotoUrl,
                Size = "lg"
            })
            <div>
                <span class="rn-eyebrow">Prontuário clínico</span>
                <h1>@Model.DisplayName</h1>
                <p>
                    <span class="rn-badge @statusBadgeClass">@StudentStatuses.Label(Model.Status)</span>
                    <span>Entrada em @Model.AdmissionDate.ToString("dd/MM/yyyy")</span>
                </p>
            </div>
        </div>
        <div class="patient-actions">
            <a class="rn-btn-primary" asp-action="Edit" asp-route-id="@Model.Id"><i class="ph ph-pencil-simple" aria-hidden="true"></i>Editar</a>
            <button class="rn-btn-secondary" type="button" onclick="window.print()"><i class="ph ph-printer" aria-hidden="true"></i>Imprimir</button>
            <button class="rn-btn-secondary" type="button" onclick="window.print()"><i class="ph ph-file-pdf" aria-hidden="true"></i>Gerar PDF</button>
            <a class="rn-btn-secondary" asp-action="Index"><i class="ph ph-arrow-left" aria-hidden="true"></i>Voltar</a>
        </div>
    </div>

    <div class="patient-kpi-grid">
        <article><small>Idade</small><strong>@age anos</strong></article>
        <article><small>Dias em tratamento</small><strong>@treatmentDays</strong></article>
        <article><small>CPF</small><strong>@Model.DisplayCpf</strong></article>
        <article><small>Telefone</small><strong>@Model.DisplayPhone</strong></article>
    </div>

    <div class="patient-profile-grid">
        <section class="patient-card">
            <div class="patient-card-title">
                <span>01</span>
                <div><h2>Dados pessoais</h2><p>Identificação principal do acolhido.</p></div>
            </div>
            <dl class="patient-data-list">
                <div><dt>Nome completo</dt><dd>@Model.DisplayName</dd></div>
                <div><dt>CPF</dt><dd>@Model.DisplayCpf</dd></div>
                <div><dt>Nascimento</dt><dd>@Model.DisplayBirthDate.ToString("dd/MM/yyyy")</dd></div>
                <div><dt>Idade</dt><dd>@age anos</dd></div>
            </dl>
        </section>

        <section class="patient-card">
            <div class="patient-card-title">
                <span>02</span>
                <div><h2>Contato</h2><p>Canais para comunicação da equipe.</p></div>
            </div>
            <dl class="patient-data-list">
                <div><dt>Telefone</dt><dd>@Model.DisplayPhone</dd></div>
                <div><dt>Email</dt><dd>@(Model.DisplayEmail ?? "Não informado")</dd></div>
                <div><dt>Endereço</dt><dd>@(Model.Address ?? "Não informado")</dd></div>
            </dl>
        </section>

        <section class="patient-card">
            <div class="patient-card-title">
                <span>03</span>
                <div><h2>Acolhimento</h2><p>Status e tempo de acompanhamento.</p></div>
            </div>
            <div class="patient-metric-row">
                <article><strong>@StudentStatuses.Label(Model.Status)</strong><small>Status atual</small></article>
                <article><strong>@treatmentDays dias</strong><small>Em tratamento</small></article>
                <article><strong>@Model.AdmissionDate.ToString("dd/MM/yyyy")</strong><small>Data de entrada</small></article>
            </div>
        </section>

        <section class="patient-card">
            <div class="patient-card-title">
                <span>04</span>
                <div><h2>Histórico</h2><p>Evoluções recentes do prontuário.</p></div>
            </div>
            <div class="patient-timeline">
                @if (evolutions.Count == 0)
                {
                    <article><strong>Acolhimento inicial</strong><p>Plano terapêutico estruturado, rotina acompanhada e evolução clínica monitorada pela equipe.</p></article>
                    <article><strong>Revisão multiprofissional</strong><p>Participação regular em atendimentos, grupos e atividades de reinserção.</p></article>
                }
                else
                {
                    @foreach (var evolution in evolutions)
                    {
                        <article>
                            <strong>@evolution.CreatedAt.ToString("dd/MM/yyyy") - @evolution.Professional.FullName</strong>
                            <p>@evolution.Description</p>
                        </article>
                    }
                }
            </div>
        </section>

        <section class="patient-card">
            <div class="patient-card-title">
                <span>05</span>
                <div><h2>Próximos atendimentos</h2><p>Agenda clínica vinculada ao acolhido.</p></div>
            </div>
            <div class="patient-list">
                @if (nextAppointments.Count == 0)
                {
                    <article><strong>Psicoterapia individual</strong><span>Agendamento demonstrativo - próxima semana</span></article>
                    <article><strong>Atendimento familiar</strong><span>Agenda sugerida para acompanhamento da rede de apoio</span></article>
                }
                else
                {
                    @foreach (var appointment in nextAppointments)
                    {
                        <article>
                            <strong>@appointment.ScheduledAt.ToString("dd/MM/yyyy HH:mm")</strong>
                            <span>@(appointment.Professional?.FullName ?? "Profissional a definir")</span>
                        </article>
                    }
                }
            </div>
        </section>

        <section class="patient-card">
            <div class="patient-card-title">
                <span>06</span>
                <div><h2>Cursos vinculados</h2><p>Engajamento nas trilhas EAD.</p></div>
            </div>
            <div class="patient-list">
                @if (courses.Count == 0)
                {
                    <article><strong>Prevenção de recaídas</strong><span>92% concluído</span></article>
                    <article><strong>Projeto de vida</strong><span>84% concluído</span></article>
                }
                else
                {
                    @foreach (var progress in courses)
                    {
                        <article>
                            <strong>@progress.Lesson.Title</strong>
                            <span>@progress.WatchedPercentage% assistido</span>
                        </article>
                    }
                }
            </div>
        </section>

        <section class="patient-card">
            <div class="patient-card-title">
                <span>07</span>
                <div><h2>Família</h2><p>Rede de apoio cadastrada.</p></div>
            </div>
            <div class="patient-list">
                @if (Model.FamilyMembers.Count == 0)
                {
                    <article><strong>Responsável principal</strong><span>Cadastro familiar pendente para demonstração</span></article>
                }
                else
                {
                    @foreach (var member in Model.FamilyMembers.Take(3))
                    {
                        <article>
                            <strong>@member.DisplayName</strong>
                            <span>@member.Relationship - @member.DisplayPhone</span>
                        </article>
                    }
                }
            </div>
        </section>

        <section class="patient-card">
            <div class="patient-card-title">
                <span>08</span>
                <div><h2>Documentos</h2><p>Checklist visual do prontuário.</p></div>
            </div>
            <div class="document-grid">
                <span class="is-ready">Documento pessoal</span>
                <span class="is-ready">Termo de acolhimento</span>
                <span>Plano terapêutico</span>
                <span>Autorização familiar</span>
            </div>
        </section>
    </div>
</section>
