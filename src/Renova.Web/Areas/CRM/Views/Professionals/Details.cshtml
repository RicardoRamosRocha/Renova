@using Renova.Domain.Entities
@model Professional
@{ ViewData["Title"] = "Detalhes do Profissional"; }
<section class="demo-page">
    <div class="demo-profile-hero"><span class="demo-photo">@Model.FullName[..1]</span><div><span class="demo-kicker">Profissional</span><h1>@Model.FullName</h1><p><span class="demo-pill @(Model.IsActive ? "ok" : "danger")">@(Model.IsActive ? "Ativo" : "Inativo")</span> @Model.Specialty</p></div><a class="demo-button" asp-action="Edit" asp-route-id="@Model.Id">Editar</a></div>
    <div class="demo-profile-meta"><article><small>Registro</small><strong>@Model.RegistrationNumber</strong></article><article><small>Telefone</small><strong>@Model.Phone</strong></article><article><small>Email</small><strong>@(Model.Email ?? "Não informado")</strong></article><article><small>Criado em</small><strong>@Model.CreatedAt.ToString("dd/MM/yyyy")</strong></article></div>
</section>
