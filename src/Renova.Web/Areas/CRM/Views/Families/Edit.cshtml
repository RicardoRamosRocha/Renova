@using Renova.Web.Areas.CRM.ViewModels.Families
@model FamilyMemberFormViewModel
@{
    ViewData["Title"] = "Editar Familiar";
}

<section class="admin-form-page">
    <header class="admin-form-header">
        <div>
            <nav class="admin-form-breadcrumb"><a asp-controller="Students" asp-action="Details" asp-route-id="@Model.StudentId">Perfil</a><span>/</span><span>Editar familiar</span></nav>
            <span class="rn-eyebrow">CRM</span>
            <h1>Editar Familiar</h1>
            <p>Atualize contato, permissões e foto sem alterar o tenant.</p>
        </div>
    </header>
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
        @await Html.PartialAsync("_Form", Model)
    </form>
</section>
