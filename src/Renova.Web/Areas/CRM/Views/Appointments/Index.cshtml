@{
    ViewData["Title"] = "Agenda";
}

<section class="demo-page">
    <div class="demo-hero">
        <div>
            <span class="demo-kicker">Calendário diário</span>
            <h1>Agenda de atendimentos</h1>
            <p>Organização por horário, equipe responsável, sala e status operacional.</p>
        </div>
        <div class="demo-button-row">
            <a class="demo-button" href="#">Novo atendimento</a>
            <a class="demo-button-secondary" href="#">Ver semana</a>
        </div>
    </div>

    <div class="demo-grid-4">
        <article class="demo-card"><span>Hoje</span><strong>32</strong><small>Atendimentos</small></article>
        <article class="demo-card"><span>Confirmados</span><strong>29</strong><small>91%</small></article>
        <article class="demo-card"><span>Em andamento</span><strong>4</strong><small>Agora</small></article>
        <article class="demo-card"><span>Remarcações</span><strong>2</strong><small>Baixo impacto</small></article>
    </div>

    <section class="demo-panel">
        <div class="demo-section-title">
            <div><span class="demo-kicker">Quinta-feira</span><h2>03 de Julho</h2></div>
            <span class="demo-pill info">Equipe completa</span>
        </div>
        <div class="demo-list">
            <article class="demo-schedule-card is-green"><strong>08:00</strong><div><strong>João Silva</strong><p class="demo-muted">Psicoterapia individual · Sala 1 · Dra. Camila Torres</p></div><span class="demo-pill ok">Confirmado</span></article>
            <article class="demo-schedule-card is-blue"><strong>09:30</strong><div><strong>Maria Oliveira</strong><p class="demo-muted">Avaliação clínica · Consultório 2 · Dr. André Moreira</p></div><span class="demo-pill info">Em preparo</span></article>
            <article class="demo-schedule-card is-yellow"><strong>11:00</strong><div><strong>Atendimento Familiar</strong><p class="demo-muted">Família Silva · Serviço social · Sala de reunião</p></div><span class="demo-pill warn">Aguardando</span></article>
            <article class="demo-schedule-card is-green"><strong>14:00</strong><div><strong>Avaliação Psicológica</strong><p class="demo-muted">Rafael Andrade · Triagem de alta · Psicologia</p></div><span class="demo-pill ok">Confirmado</span></article>
            <article class="demo-schedule-card is-blue"><strong>16:00</strong><div><strong>Grupo Terapêutico</strong><p class="demo-muted">12 acolhidos · Tema: prevenção de recaídas</p></div><span class="demo-pill info">Coletivo</span></article>
            <article class="demo-schedule-card is-red"><strong>17:30</strong><div><strong>Revisão de plano</strong><p class="demo-muted">Equipe multidisciplinar · Sala diretoria clínica</p></div><span class="demo-pill danger">Prioridade</span></article>
        </div>
    </section>
</section>
