@{
    ViewData["Title"] = "Agenda";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <span>Calendário diário</span>
            <h1>Agenda de atendimentos</h1>
            <p>Organização por horário, equipe responsável, sala e status operacional.</p>
        </div>
        <div class="rn-inline">
            <a class="rn-btn-primary" href="#"><i class="ph ph-calendar-plus" aria-hidden="true"></i>Novo atendimento</a>
            <a class="rn-btn-secondary" href="#"><i class="ph ph-calendar" aria-hidden="true"></i>Ver semana</a>
        </div>
    </div>

    <div class="demo-grid-4">
        <article class="rn-metric-card"><span>Hoje</span><strong>32</strong><small>Atendimentos</small></article>
        <article class="rn-metric-card"><span>Confirmados</span><strong>29</strong><small>91%</small></article>
        <article class="rn-metric-card"><span>Em andamento</span><strong>4</strong><small>Agora</small></article>
        <article class="rn-metric-card"><span>Remarcações</span><strong>2</strong><small>Baixo impacto</small></article>
    </div>

    <section class="demo-panel">
        <div class="demo-section-title">
            <div><span class="rn-eyebrow">Quinta-feira</span><h2>03 de Julho</h2></div>
            <span class="rn-badge rn-badge-info">Equipe completa</span>
        </div>
        <div class="demo-list">
            <article class="demo-schedule-card is-green"><strong>08:00</strong><div><strong>João Silva</strong><p class="rn-muted">Psicoterapia individual · Sala 1 · Dra. Camila Torres</p></div><span class="rn-badge rn-badge-success">Confirmado</span></article>
            <article class="demo-schedule-card is-blue"><strong>09:30</strong><div><strong>Maria Oliveira</strong><p class="rn-muted">Avaliação clínica · Consultório 2 · Dr. André Moreira</p></div><span class="rn-badge rn-badge-info">Em preparo</span></article>
            <article class="demo-schedule-card is-yellow"><strong>11:00</strong><div><strong>Atendimento Familiar</strong><p class="rn-muted">Família Silva · Serviço social · Sala de reunião</p></div><span class="rn-badge rn-badge-warning">Aguardando</span></article>
            <article class="demo-schedule-card is-green"><strong>14:00</strong><div><strong>Avaliação Psicológica</strong><p class="rn-muted">Rafael Andrade · Triagem de alta · Psicologia</p></div><span class="rn-badge rn-badge-success">Confirmado</span></article>
            <article class="demo-schedule-card is-blue"><strong>16:00</strong><div><strong>Grupo Terapêutico</strong><p class="rn-muted">12 acolhidos · Tema: prevenção de recaídas</p></div><span class="rn-badge rn-badge-info">Coletivo</span></article>
            <article class="demo-schedule-card is-red"><strong>17:30</strong><div><strong>Revisão de plano</strong><p class="rn-muted">Equipe multidisciplinar · Sala diretoria clínica</p></div><span class="rn-badge rn-badge-danger">Prioridade</span></article>
        </div>
    </section>
</section>
