@using Renova.Web.Areas.CRM.ViewModels.Appointments
@using Renova.Web.ViewModels
@model AppointmentIndexViewModel
@{
    ViewData["Title"] = "Agenda";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <span>Calendário diário</span>
            <h1>Agenda de atendimentos</h1>
            <p>Atendimentos reais filtrados pelo tenant atual via acolhido vinculado.</p>
        </div>
        <form class="rn-inline" method="get">
            <input class="admin-input" name="date" value="@Model.Date.ToString("yyyy-MM-dd")" type="date" />
            <button class="rn-btn-secondary" type="submit"><i class="ph ph-calendar" aria-hidden="true"></i>Ver data</button>
        </form>
    </div>

    <div class="crm-metrics-grid">
        <article class="rn-metric-card"><span>Total</span><strong>@Model.Total</strong><small>@Model.Date.ToString("dd/MM/yyyy")</small></article>
        <article class="rn-metric-card"><span>Agendados</span><strong>@Model.Scheduled</strong><small>Status 1</small></article>
        <article class="rn-metric-card"><span>Concluídos</span><strong>@Model.Completed</strong><small>Status 2</small></article>
        <article class="rn-metric-card"><span>Cancelados</span><strong>@Model.Cancelled</strong><small>Status 3</small></article>
    </div>

    <section class="renova-table-card">
        @if (Model.Appointments.Count == 0)
        {
            <div class="crm-empty-state">
                <div class="crm-empty-icon"><i class="ph ph-calendar-check" aria-hidden="true"></i></div>
                <strong>Nenhum atendimento encontrado</strong>
                <p>Não há atendimentos registrados para a data selecionada.</p>
            </div>
        }
        else
        {
            <div class="renova-table-wrap">
                <table class="renova-table">
                    <thead><tr><th>Horário</th><th>Acolhido</th><th>Profissional</th><th>Status</th><th>Notas</th></tr></thead>
                    <tbody>
                    @foreach (var appointment in Model.Appointments)
                    {
                        <tr>
                            <td>@appointment.ScheduledAt.ToString("HH:mm")</td>
                            <td>
                                <a class="renova-person-cell" asp-controller="Students" asp-action="Details" asp-route-id="@appointment.StudentId">
                                    @await Html.PartialAsync("~/Views/Shared/_ProfileAvatar.cshtml", new ProfileAvatarViewModel
                                    {
                                        Name = appointment.StudentName,
                                        PhotoUrl = appointment.StudentPhotoUrl
                                    })
                                    <span><strong class="renova-row-title">@appointment.StudentName</strong></span>
                                </a>
                            </td>
                            <td>@(appointment.ProfessionalName ?? "Não definido")</td>
                            <td><span class="renova-status-badge info">@appointment.Status</span></td>
                            <td>@(appointment.Notes ?? "Sem notas")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </section>
</section>
