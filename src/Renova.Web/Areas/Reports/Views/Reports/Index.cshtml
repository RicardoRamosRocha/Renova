@{
    ViewData["Title"] = "Relatórios";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <span>Inteligência operacional</span>
            <h1>Relatórios</h1>
            <p>Indicadores prontos para diretoria, equipe clínica, financeiro e EAD.</p>
        </div>
        <div class="rn-inline">
            <a class="rn-btn-primary" href="#"><i class="ph ph-file-pdf" aria-hidden="true"></i>Exportar PDF</a>
            <a class="rn-btn-secondary" href="#"><i class="ph ph-file-xls" aria-hidden="true"></i>Exportar Excel</a>
        </div>
    </div>

    <div class="demo-grid-4">
        <article class="rn-card rn-stack">
            <span class="demo-card-icon"><i class="ph ph-users-three" aria-hidden="true"></i></span>
            <h2>Relatório de Acolhidos</h2>
            <p class="rn-muted">Entradas, altas, status, evolução de tratamento e perfil institucional.</p>
            <a class="rn-btn-secondary" href="#">Abrir relatório</a>
        </article>
        <article class="rn-card rn-stack">
            <span class="demo-card-icon"><i class="ph ph-currency-circle-dollar" aria-hidden="true"></i></span>
            <h2>Relatório Financeiro</h2>
            <p class="rn-muted">Receita, despesas, inadimplência, cobranças e previsão de caixa.</p>
            <a class="rn-btn-secondary" href="#">Abrir relatório</a>
        </article>
        <article class="rn-card rn-stack">
            <span class="demo-card-icon"><i class="ph ph-stethoscope" aria-hidden="true"></i></span>
            <h2>Relatório Clínico</h2>
            <p class="rn-muted">Atendimentos, evoluções, riscos, documentos e produtividade técnica.</p>
            <a class="rn-btn-secondary" href="#">Abrir relatório</a>
        </article>
        <article class="rn-card rn-stack">
            <span class="demo-card-icon"><i class="ph ph-graduation-cap" aria-hidden="true"></i></span>
            <h2>Relatório EAD</h2>
            <p class="rn-muted">Engajamento, progresso, certificados, cursos mais acessados e trilhas.</p>
            <a class="rn-btn-secondary" href="#">Abrir relatório</a>
        </article>
    </div>

    <section class="demo-panel">
        <div class="demo-section-title">
            <div><span class="rn-eyebrow">Resumo executivo</span><h2>Indicadores do mês</h2></div>
        </div>
        <div class="demo-grid-3">
            <article class="rn-metric-card"><span>Taxa de ocupação</span><strong>87%</strong><small>Dentro da meta</small></article>
            <article class="rn-metric-card"><span>Alta terapêutica</span><strong>18</strong><small>Previstas no mês</small></article>
            <article class="rn-metric-card"><span>Engajamento EAD</span><strong>74%</strong><small>Alunos ativos</small></article>
        </div>
    </section>
</section>
