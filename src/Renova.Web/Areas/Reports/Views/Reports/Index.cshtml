@{
    ViewData["Title"] = "Relatórios";
}

<section class="demo-page">
    <div class="demo-hero">
        <div>
            <span class="demo-kicker">Inteligência operacional</span>
            <h1>Relatórios</h1>
            <p>Indicadores prontos para diretoria, equipe clínica, financeiro e EAD.</p>
        </div>
        <div class="demo-button-row">
            <a class="demo-button" href="#">Exportar PDF</a>
            <a class="demo-button-secondary" href="#">Exportar Excel</a>
        </div>
    </div>

    <div class="demo-grid-4">
        <article class="demo-card demo-report-card">
            <span class="demo-card-icon">👥</span>
            <h2>Relatório de Acolhidos</h2>
            <p class="demo-muted">Entradas, altas, status, evolução de tratamento e perfil institucional.</p>
            <a class="demo-button-secondary" href="#">Abrir relatório</a>
        </article>
        <article class="demo-card demo-report-card">
            <span class="demo-card-icon">💰</span>
            <h2>Relatório Financeiro</h2>
            <p class="demo-muted">Receita, despesas, inadimplência, cobranças e previsão de caixa.</p>
            <a class="demo-button-secondary" href="#">Abrir relatório</a>
        </article>
        <article class="demo-card demo-report-card">
            <span class="demo-card-icon">✚</span>
            <h2>Relatório Clínico</h2>
            <p class="demo-muted">Atendimentos, evoluções, riscos, documentos e produtividade técnica.</p>
            <a class="demo-button-secondary" href="#">Abrir relatório</a>
        </article>
        <article class="demo-card demo-report-card">
            <span class="demo-card-icon">📚</span>
            <h2>Relatório EAD</h2>
            <p class="demo-muted">Engajamento, progresso, certificados, cursos mais acessados e trilhas.</p>
            <a class="demo-button-secondary" href="#">Abrir relatório</a>
        </article>
    </div>

    <section class="demo-panel">
        <div class="demo-section-title">
            <div><span class="demo-kicker">Resumo executivo</span><h2>Indicadores do mês</h2></div>
        </div>
        <div class="demo-grid-3">
            <article class="demo-card"><span>Taxa de ocupação</span><strong>87%</strong><small>Dentro da meta</small></article>
            <article class="demo-card"><span>Alta terapêutica</span><strong>18</strong><small>Previstas no mês</small></article>
            <article class="demo-card"><span>Engajamento EAD</span><strong>74%</strong><small>Alunos ativos</small></article>
        </div>
    </section>
</section>
