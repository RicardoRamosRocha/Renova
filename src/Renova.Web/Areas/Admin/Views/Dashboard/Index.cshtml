@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<section class="demo-page">
    <div class="demo-hero">
        <div>
            <span class="demo-kicker">Painel inteligente</span>
            <h1>Bom dia, Ricardo!</h1>
            <p>
                Hoje há <strong>34 acolhidos em tratamento</strong>,
                <strong>6 atendimentos agendados</strong>,
                <strong>2 altas previstas</strong> e
                <strong>1 curso novo publicado</strong>.
            </p>
        </div>

        <div class="demo-button-row rn-inline">
            <a class="demo-button" asp-area="CRM" asp-controller="Students" asp-action="Create">
                <i class="ph ph-user-plus" aria-hidden="true"></i>
                Novo acolhido
            </a>
            <a class="demo-button-secondary" asp-area="Reports" asp-controller="Reports" asp-action="Index">
                <i class="ph ph-chart-line-up" aria-hidden="true"></i>
                Ver relatórios
            </a>
        </div>
    </div>

    <div class="demo-grid-6">
        <article class="demo-card">
            <span class="demo-card-icon"><i class="ph ph-users-three" aria-hidden="true"></i></span>
            <span>Acolhidos ativos</span>
            <strong>126</strong>
            <small>+8% neste mês</small>
        </article>
        <article class="demo-card">
            <span class="demo-card-icon"><i class="ph ph-calendar-check" aria-hidden="true"></i></span>
            <span>Atendimentos hoje</span>
            <strong>32</strong>
            <small>91% confirmados</small>
        </article>
        <article class="demo-card">
            <span class="demo-card-icon"><i class="ph ph-graduation-cap" aria-hidden="true"></i></span>
            <span>Cursos publicados</span>
            <strong>18</strong>
            <small>4 trilhas novas</small>
        </article>
        <article class="demo-card">
            <span class="demo-card-icon"><i class="ph ph-student" aria-hidden="true"></i></span>
            <span>Alunos estudando</span>
            <strong>94</strong>
            <small>72% engajados</small>
        </article>
        <article class="demo-card">
            <span class="demo-card-icon"><i class="ph ph-currency-circle-dollar" aria-hidden="true"></i></span>
            <span>Mensalidades em aberto</span>
            <strong>7</strong>
            <small>R$ 12.840</small>
        </article>
        <article class="demo-card">
            <span class="demo-card-icon"><i class="ph ph-warning-circle" aria-hidden="true"></i></span>
            <span>Alertas importantes</span>
            <strong>4</strong>
            <small>Prioridade alta</small>
        </article>
    </div>

    <div class="demo-dashboard-grid">
        <div class="demo-side-stack">
            <section class="demo-panel">
                <div class="demo-section-title">
                    <div>
                        <span class="demo-kicker">Evolução mensal</span>
                        <h2>Indicadores de acolhimento</h2>
                    </div>
                    <span class="demo-pill info">Últimos 5 meses</span>
                </div>

                <div class="admin-chart-placeholder" aria-label="Placeholder de gráfico de evolução">
                    <span></span>
                    <span></span>
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
            </section>

            <section class="demo-panel demo-highlight-panel">
                <div class="demo-section-title">
                    <div>
                        <span class="demo-kicker">Alertas inteligentes</span>
                        <h2>O que merece atenção hoje</h2>
                    </div>
                    <span class="demo-pill warn">4 alertas</span>
                </div>

                <div class="demo-alert-grid">
                    <article class="demo-alert-card">
                        <div class="demo-alert-icon"><i class="ph ph-bell-ringing" aria-hidden="true"></i></div>
                        <div>
                            <strong>Marco importante</strong>
                            <span>João Silva completa 90 dias de tratamento hoje.</span>
                        </div>
                    </article>
                    <article class="demo-alert-card">
                        <div class="demo-alert-icon"><i class="ph ph-users-four" aria-hidden="true"></i></div>
                        <div>
                            <strong>Agenda familiar</strong>
                            <span>Reunião com familiares agendada para 14h.</span>
                        </div>
                    </article>
                    <article class="demo-alert-card">
                        <div class="demo-alert-icon"><i class="ph ph-books" aria-hidden="true"></i></div>
                        <div>
                            <strong>EAD em movimento</strong>
                            <span>Curso de prevenção à recaída concluído por 8 acolhidos.</span>
                        </div>
                    </article>
                    <article class="demo-alert-card">
                        <div class="demo-alert-icon"><i class="ph ph-receipt" aria-hidden="true"></i></div>
                        <div>
                            <strong>Financeiro</strong>
                            <span>Existem 3 mensalidades pendentes para acompanhamento.</span>
                        </div>
                    </article>
                </div>
            </section>

            <section class="demo-panel">
                <div class="demo-section-title">
                    <div>
                        <span class="demo-kicker">Movimentações</span>
                        <h2>Atividades recentes</h2>
                    </div>
                </div>

                <div class="rn-timeline">
                    <article class="rn-timeline-item"><strong>Novo acolhido cadastrado</strong><span class="rn-muted">há 12 min</span></article>
                    <article class="rn-timeline-item"><strong>Curso publicado</strong><span class="rn-muted">há 36 min</span></article>
                    <article class="rn-timeline-item"><strong>Alta terapêutica registrada</strong><span class="rn-muted">10:14</span></article>
                    <article class="rn-timeline-item"><strong>Novo profissional adicionado</strong><span class="rn-muted">09:52</span></article>
                    <article class="rn-timeline-item"><strong>Pagamento confirmado</strong><span class="rn-muted">09:18</span></article>
                </div>
            </section>
        </div>

        <aside class="demo-side-stack">
            <section class="demo-panel">
                <div class="demo-section-title">
                    <h2>Ações rápidas</h2>
                </div>
                <div class="rn-stack">
                    <a class="demo-button-secondary" asp-area="CRM" asp-controller="Appointments" asp-action="Index"><i class="ph ph-calendar-plus" aria-hidden="true"></i>Nova agenda</a>
                    <a class="demo-button-secondary" asp-area="Medical" asp-controller="Professionals" asp-action="Index"><i class="ph ph-stethoscope" aria-hidden="true"></i>Profissionais</a>
                    <a class="demo-button-secondary" asp-area="EAD" asp-controller="Courses" asp-action="Index"><i class="ph ph-video" aria-hidden="true"></i>Cursos</a>
                </div>
            </section>

            <section class="demo-panel">
                <div class="demo-section-title"><h2>Próximos aniversariantes</h2></div>
                <div class="demo-mini-list">
                    <span>Ana Paula <strong>05/07</strong></span>
                    <span>Renato Lima <strong>08/07</strong></span>
                    <span>Clara Nunes <strong>11/07</strong></span>
                </div>
            </section>

            <section class="demo-panel">
                <div class="demo-section-title"><h2>Documentos pendentes</h2></div>
                <div class="demo-mini-list">
                    <span>Termos LGPD <strong>4</strong></span>
                    <span>Relatórios médicos <strong>6</strong></span>
                    <span>Contratos familiares <strong>3</strong></span>
                </div>
            </section>

            <section class="demo-panel">
                <div class="demo-section-title"><h2>Cursos mais acessados</h2></div>
                <div class="demo-mini-list">
                    <span>Prevenção à recaída <strong>82%</strong></span>
                    <span>Família e reintegração <strong>74%</strong></span>
                    <span>Rotina saudável <strong>69%</strong></span>
                </div>
            </section>
        </aside>
    </div>
</section>
