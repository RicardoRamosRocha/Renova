@{
    var userName = User.Identity?.Name;
    var currentArea = ViewContext.RouteData.Values["area"]?.ToString();
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var contextLabel = currentArea switch
    {
        "CRM" => "Relacionamento e acolhimento",
        "Medical" => "Cuidado clínico",
        "EAD" => "Educação digital",
        "Finance" => "Gestão financeira",
        "Reports" => "Inteligência operacional",
        "Settings" => "Configurações do sistema",
        "Admin" when currentController == "Dashboard" => "Visão executiva",
        "Admin" => "Administração",
        _ => "Gestão integrada"
    };
}

<header class="admin-topbar">
    <div class="admin-topbar-title">
        <span>Painel Renova</span>
        <strong>@contextLabel</strong>
    </div>

    <div class="admin-topbar-actions">
        <label class="admin-search">
            <span class="sr-only">Buscar no painel</span>
            <i class="ph ph-magnifying-glass" aria-hidden="true"></i>
            <input type="search" placeholder="Buscar..." />
        </label>

        <div class="admin-user" aria-label="Usuário logado">
            <span>@((userName ?? "Admin").Substring(0, 1).ToUpperInvariant())</span>
            <div>
                <strong>@(userName ?? "Usuário Renova")</strong>
                <small>Online</small>
            </div>
        </div>
    </div>
</header>
