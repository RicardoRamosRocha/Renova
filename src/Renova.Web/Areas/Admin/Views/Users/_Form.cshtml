@using Renova.Web.Areas.Admin.ViewModels.Users
@model UserFormViewModel
@{
    var roles = (IReadOnlyList<string>)(ViewBag.Roles ?? new List<string>());
}

<input type="hidden" asp-for="Id" />
<div asp-validation-summary="ModelOnly" class="admin-validation-summary"></div>

<div class="admin-form-card">
    <section class="admin-form-section">
        <div class="admin-form-section-title">
            <div><span class="rn-eyebrow">Identificação</span><h2>Dados do usuário</h2><p>Informações básicas da conta utilizada para acessar o Renova.</p></div>
        </div>
        <div class="admin-form-grid">
            <div class="admin-form-group"><label class="admin-label required" asp-for="FullName">Nome completo</label><input class="admin-input" asp-for="FullName" autocomplete="name" /><span class="admin-validation" asp-validation-for="FullName"></span></div>
            <div class="admin-form-group"><label class="admin-label required" asp-for="Email">Email</label><input class="admin-input" asp-for="Email" autocomplete="email" /><span class="admin-validation" asp-validation-for="Email"></span></div>
            <div class="admin-form-group"><label class="admin-label" asp-for="Phone">Telefone</label><input class="admin-input" asp-for="Phone" inputmode="tel" autocomplete="tel" /><span class="admin-validation" asp-validation-for="Phone"></span></div>
            <div class="admin-form-group"><label class="admin-label" asp-for="IsActive">Status</label><select class="admin-select" asp-for="IsActive"><option value="true">Ativo</option><option value="false">Inativo</option></select><span class="admin-validation" asp-validation-for="IsActive"></span></div>
        </div>
    </section>

    <section class="admin-form-section">
        <div class="admin-form-section-title">
            <div><span class="rn-eyebrow">Acesso</span><h2>Perfil e senha</h2><p>Defina o perfil de acesso e, se necessário, uma senha provisória.</p></div>
        </div>
        <div class="admin-form-grid">
            <div class="admin-form-group">
                <label class="admin-label" asp-for="Role">Perfil/Role</label>
                <select class="admin-select" asp-for="Role">
                    <option value="">Sem perfil</option>
                    @foreach (var role in roles)
                    {
                        <option value="@role">@role</option>
                    }
                </select>
                <span class="admin-validation" asp-validation-for="Role"></span>
            </div>
            <div class="admin-form-group">
                <label class="admin-label" asp-for="TemporaryPassword">Senha provisória</label>
                <input class="admin-input" asp-for="TemporaryPassword" placeholder="Opcional ao editar" />
                <span class="admin-help-text">Use apenas quando desejar criar ou redefinir uma senha provisória.</span>
                <span class="admin-validation" asp-validation-for="TemporaryPassword"></span>
            </div>
        </div>
    </section>

    <div class="admin-form-actions">
        <a class="rn-btn-secondary" asp-action="Index">Cancelar</a>
        <button class="rn-btn-primary" type="submit"><i class="ph ph-check-circle" aria-hidden="true"></i>Salvar usuário</button>
    </div>
</div>
