@using Renova.Infrastructure.Identity
@using Renova.Web.ViewModels
@model PagedResult<ApplicationUser>
@{
    ViewData["Title"] = "Usuários";
}

<section class="admin-page">
    <div class="admin-page-header">
        <div>
            <span>Admin / Usuários</span>
            <h1>Usuários</h1>
            <p>Gerencie contas, perfis de acesso e status dos usuários.</p>
        </div>
        <a class="rn-btn-primary" asp-action="Create"><i class="ph ph-user-plus" aria-hidden="true"></i>Novo usuário</a>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="rn-alert rn-alert-success"><i class="ph ph-check-circle" aria-hidden="true"></i>@success</div>
    }

    <div class="demo-grid-4">
        <article class="rn-metric-card"><span>Usuários</span><strong>@ViewBag.Total</strong><small>Total</small></article>
        <article class="rn-metric-card"><span>Ativos</span><strong>@ViewBag.ActiveCount</strong><small>Com acesso</small></article>
        <article class="rn-metric-card"><span>Inativos</span><strong>@ViewBag.InactiveCount</strong><small>Bloqueados</small></article>
        <article class="rn-metric-card"><span>Perfis</span><strong>@ViewBag.RolesCount</strong><small>Roles</small></article>
    </div>

    <section class="renova-table-card">
        <div class="renova-table-header">
            <div>
                <span class="rn-eyebrow">Busca e filtros</span>
                <h2>Lista de usuários</h2>
                <p>Visualize contas, status e ações administrativas.</p>
            </div>
            <form class="demo-filter-row" method="get">
                <input name="search" value="@ViewBag.Search" type="search" placeholder="Pesquisar por nome ou email" />
                <select name="active">
                    <option value="">Todos os status</option>
                    <option value="true" selected="@(ViewBag.Active == true)">Ativo</option>
                    <option value="false" selected="@(ViewBag.Active == false)">Inativo</option>
                </select>
                <button class="rn-btn-secondary" type="submit"><i class="ph ph-funnel" aria-hidden="true"></i>Filtrar</button>
            </form>
        </div>

        @if (Model.Items.Count == 0)
        {
            <div class="crm-empty-state">
                <div class="crm-empty-icon"><i class="ph ph-user-circle" aria-hidden="true"></i></div>
                <strong>Nenhum registro encontrado</strong>
                <p>Crie usuários administrativos para a demonstração.</p>
                <a class="rn-btn-primary" asp-action="Create"><i class="ph ph-plus" aria-hidden="true"></i>Criar primeiro cadastro</a>
            </div>
        }
        else
        {
            <div class="renova-table-wrap">
                <table class="renova-table">
                    <thead>
                        <tr>
                            <th>Nome</th>
                            <th>Email</th>
                            <th>Telefone</th>
                            <th>Criado em</th>
                            <th>Situação</th>
                            <th class="text-end">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var user in Model.Items)
                    {
                        <tr>
                            <td>
                                <div class="renova-person-cell">
                                    @await Html.PartialAsync("~/Views/Shared/_ProfileAvatar.cshtml", new ProfileAvatarViewModel
                                    {
                                        Name = user.FullName,
                                        PhotoUrl = user.PhotoPath
                                    })
                                    <span>
                                        <strong class="renova-row-title">@user.FullName</strong>
                                        <small class="renova-row-subtitle">Conta administrativa</small>
                                    </span>
                                </div>
                            </td>
                            <td><span class="renova-muted">@user.Email</span></td>
                            <td><span class="renova-muted">@(user.PhoneNumber ?? "Não informado")</span></td>
                            <td><span class="renova-muted">@user.CreatedAt.ToString("dd/MM/yyyy")</span></td>
                            <td><span class="renova-status-badge @(user.IsActive ? "ok" : "danger")">@(user.IsActive ? "Ativo" : "Inativo")</span></td>
                            <td>
                                <div class="renova-action-buttons">
                                    <a class="renova-action-btn" title="Detalhes" asp-action="Details" asp-route-id="@user.Id"><i class="ph ph-eye" aria-hidden="true"></i></a>
                                    <a class="renova-action-btn" title="Editar" asp-action="Edit" asp-route-id="@user.Id"><i class="ph ph-pencil-simple" aria-hidden="true"></i></a>
                                    <a class="renova-action-btn danger" title="Excluir" href="#delete-user-@user.Id"><i class="ph ph-trash" aria-hidden="true"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>

            @await Html.PartialAsync("~/Views/Shared/_Pagination.cshtml", Model)

            @foreach (var user in Model.Items)
            {
                <div id="delete-user-@user.Id" class="admin-delete-modal" role="dialog" aria-modal="true">
                    <div class="admin-delete-dialog">
                        <h2>Excluir usuário</h2>
                        <p>Deseja realmente excluir este registro? Caso não seja possível excluir, o usuário será inativado com segurança.</p>
                        <div class="admin-delete-actions">
                            <a class="rn-btn-secondary" href="#">Cancelar</a>
                            <form asp-action="Delete" asp-route-id="@user.Id" method="post"><button class="rn-btn-danger" type="submit">Excluir</button></form>
                        </div>
                    </div>
                </div>
            }
        }
    </section>
</section>
