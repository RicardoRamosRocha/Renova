@using Renova.Infrastructure.Identity
@using Renova.Web.ViewModels
@model PagedResult<ApplicationUser>
@{ ViewData["Title"] = "Usuários"; }

<section class="demo-page">
    <div class="demo-hero">
        <div><span class="demo-kicker">Admin / Usuários</span><h1>Usuários</h1><p>Gerencie contas, perfis de acesso e status dos usuários.</p></div>
        <a class="demo-button" asp-action="Create">Novo Usuário</a>
    </div>
    @if (TempData["Success"] is string success) { <div class="admin-alert">@success</div> }
    <div class="demo-grid-4">
        <article class="demo-card"><span>Usuários</span><strong>@ViewBag.Total</strong><small>Total</small></article>
        <article class="demo-card"><span>Ativos</span><strong>@ViewBag.ActiveCount</strong><small>Com acesso</small></article>
        <article class="demo-card"><span>Inativos</span><strong>@ViewBag.InactiveCount</strong><small>Bloqueados</small></article>
        <article class="demo-card"><span>Perfis</span><strong>@ViewBag.RolesCount</strong><small>Roles</small></article>
    </div>
    <section class="demo-panel">
        <div class="demo-section-title">
            <div><span class="demo-kicker">Busca e filtros</span><h2>Lista de usuários</h2></div>
            <form class="demo-filter-row" method="get">
                <input name="search" value="@ViewBag.Search" type="search" placeholder="Pesquisar por nome ou email" />
                <select name="active"><option value="">Todos os status</option><option value="true" selected="@(ViewBag.Active == true)">Ativo</option><option value="false" selected="@(ViewBag.Active == false)">Inativo</option></select>
                <button class="demo-button-secondary" type="submit">Filtrar</button>
            </form>
        </div>
        @if (Model.Items.Count == 0)
        {
            <div class="admin-empty-state"><strong>Nenhum registro encontrado.</strong><p>Crie usuários administrativos para a demonstração.</p><a class="demo-button" asp-action="Create">Criar primeiro cadastro</a></div>
        }
        else
        {
            <div class="demo-table-wrap">
                <table class="demo-table">
                    <thead><tr><th>Nome</th><th>Email</th><th>Telefone</th><th>Criado em</th><th>Situação</th><th>Ações</th></tr></thead>
                    <tbody>
                    @foreach (var user in Model.Items)
                    {
                        <tr>
                            <td><div class="demo-person"><span class="demo-avatar">@user.FullName[..1]</span><strong>@user.FullName</strong></div></td>
                            <td>@user.Email</td>
                            <td>@(user.PhoneNumber ?? "Não informado")</td>
                            <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td><span class="demo-pill @(user.IsActive ? "ok" : "danger")">@(user.IsActive ? "Ativo" : "Inativo")</span></td>
                            <td><div class="admin-table-actions"><a class="admin-action-button details" asp-action="Details" asp-route-id="@user.Id">Detalhes</a><a class="admin-action-button edit" asp-action="Edit" asp-route-id="@user.Id">Editar</a><a class="admin-action-button danger" href="#delete-user-@user.Id">Excluir</a></div></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
            @await Html.PartialAsync("~/Views/Shared/_Pagination.cshtml", Model)
            @foreach (var user in Model.Items)
            {
                <div id="delete-user-@user.Id" class="admin-delete-modal" role="dialog" aria-modal="true">
                    <div class="admin-delete-dialog">
                        <h2>Excluir usuário</h2>
                        <p>Deseja realmente excluir este registro? Caso não seja possível excluir, o usuário será inativado com segurança.</p>
                        <div class="admin-delete-actions">
                            <a class="admin-button-secondary" href="#">Cancelar</a>
                            <form asp-action="Delete" asp-route-id="@user.Id" method="post"><button class="admin-action-button danger" type="submit">Excluir</button></form>
                        </div>
                    </div>
                </div>
            }
        }
    </section>
</section>
