@using Renova.Web.Areas.EAD.ViewModels.Courses
@model CourseIndexViewModel
@{
    ViewData["Title"] = "Cursos";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<section class="ead-page">
    <div class="ead-page-header">
        <div>
            <span class="ead-eyebrow">Plataforma EAD</span>
            <h1>Biblioteca de Cursos</h1>
            <p>Cursos ligados a trilhas terapêuticas, progresso real dos acolhidos e certificados emitidos.</p>
        </div>

        <a class="ead-primary-button" asp-area="EAD" asp-controller="Courses" asp-action="Create">
            <i class="ph ph-plus" aria-hidden="true"></i>
            Novo curso
        </a>
    </div>

    <div class="ead-metrics-grid">
        <article class="ead-metric-card"><span>Cursos ativos</span><strong>@Model.ActiveCourses</strong><small>@Model.TotalCourses cadastrados</small></article>
        <article class="ead-metric-card"><span>Alunos estudando</span><strong>@Model.StudyingStudents</strong><small>Tenant atual</small></article>
        <article class="ead-metric-card"><span>Certificados</span><strong>@Model.Certificates</strong><small>Emitidos</small></article>
        <article class="ead-metric-card"><span>Engajamento</span><strong>@Model.AverageProgress%</strong><small>Progresso médio</small></article>
    </div>

    <form class="ead-filter-bar" method="get">
        <label class="ead-search-box">
            <i class="ph ph-magnifying-glass" aria-hidden="true"></i>
            <input name="search" value="@Model.Search" type="search" placeholder="Pesquisar curso, trilha ou descrição..." />
        </label>
        <select name="active">
            <option value="">Todos os status</option>
            <option value="true" selected="@(Model.Active == true)">Publicado</option>
            <option value="false" selected="@(Model.Active == false)">Arquivado</option>
        </select>
        <select name="trail">
            <option value="">Todas as trilhas</option>
            @foreach (var trail in Model.Trails)
            {
                <option value="@trail" selected="@(Model.Trail == trail)">@trail</option>
            }
        </select>
        <button class="ead-secondary-button" type="submit"><i class="ph ph-funnel" aria-hidden="true"></i>Filtrar</button>
    </form>

    @if (Model.Courses.Items.Count == 0)
    {
        <section class="crm-empty-state">
            <div class="crm-empty-icon"><i class="ph ph-graduation-cap" aria-hidden="true"></i></div>
            <strong>Nenhum curso encontrado</strong>
            <p>Crie cursos ou ajuste os filtros da biblioteca EAD.</p>
        </section>
    }
    else
    {
        <div class="ead-course-grid">
            @foreach (var course in Model.Courses.Items)
            {
                var statusClass = course.IsActive ? "rn-badge-success" : "rn-badge-warning";

                <article class="ead-course-card">
                    <div class="ead-course-visual">
                        <i class="ph @course.Icon" aria-hidden="true"></i>
                    </div>

                    <div class="ead-course-body">
                        <div class="ead-course-meta">
                            <span class="rn-badge rn-badge-info">@course.Trail</span>
                            <span class="rn-badge @statusClass">@(course.IsActive ? "Publicado" : "Arquivado")</span>
                        </div>

                        <div>
                            <h2>@course.Title</h2>
                            <p>@course.Description</p>
                        </div>

                        <div class="ead-info-grid">
                            <div><small>Professor</small><strong>@course.Teacher</strong></div>
                            <div><small>Carga horária</small><strong>@course.WorkloadHours h</strong></div>
                            <div><small>Nível</small><strong>@course.Level</strong></div>
                            <div><small>Duração</small><strong>@course.DurationInMinutes min</strong></div>
                        </div>

                        <div class="rn-stack">
                            <div class="ead-progress-label"><span>Progresso médio</span><strong>@course.AverageProgress%</strong></div>
                            <div class="ead-progress-track"><div class="ead-progress-fill" style="width:@course.AverageProgress%;"></div></div>
                        </div>

                        <div class="ead-course-stats">
                            <span><i class="ph ph-play-circle" aria-hidden="true"></i> @course.Lessons aulas</span>
                            <span><i class="ph ph-users-three" aria-hidden="true"></i> @course.Students alunos</span>
                            <span><i class="ph ph-certificate" aria-hidden="true"></i> @course.Certificates certificados</span>
                        </div>

                        <div class="ead-card-actions">
                            <a class="ead-primary-button" asp-area="EAD" asp-controller="Courses" asp-action="Details" asp-route-id="@course.Id">Abrir</a>
                            <a class="ead-secondary-button" asp-area="EAD" asp-controller="Courses" asp-action="Edit" asp-route-id="@course.Id">Editar</a>
                        </div>
                    </div>
                </article>
            }
        </div>

        @await Html.PartialAsync("~/Views/Shared/_Pagination.cshtml", Model.Courses)
    }
</section>
