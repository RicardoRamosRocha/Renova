@{
    ViewData["Title"] = "Cursos";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    var courses = new[]
    {
        new { Icon = "🧠", Title = "Prevenção à Recaída", Category = "Psicoeducação", Teacher = "Equipe Terapêutica", Hours = "24h", Lessons = 18, Students = 86, Certificates = 31, Progress = 84, Status = "Publicado", Color = "blue" },
        new { Icon = "👨‍👩‍👧", Title = "Família e Reinserção Social", Category = "Família", Teacher = "Serviço Social", Hours = "16h", Lessons = 12, Students = 43, Certificates = 17, Progress = 62, Status = "Publicado", Color = "emerald" },
        new { Icon = "💙", Title = "Inteligência Emocional", Category = "Desenvolvimento", Teacher = "Psicologia", Hours = "20h", Lessons = 15, Students = 72, Certificates = 24, Progress = 76, Status = "Publicado", Color = "indigo" },
        new { Icon = "🙏", Title = "Espiritualidade e Propósito", Category = "Valores", Teacher = "Coordenação", Hours = "12h", Lessons = 10, Students = 58, Certificates = 19, Progress = 68, Status = "Publicado", Color = "amber" },
        new { Icon = "🏃", Title = "Rotina Saudável", Category = "Saúde", Teacher = "Educador Físico", Hours = "10h", Lessons = 8, Students = 91, Certificates = 44, Progress = 89, Status = "Publicado", Color = "green" },
        new { Icon = "🎯", Title = "Projeto de Vida", Category = "Planejamento", Teacher = "Equipe Pedagógica", Hours = "18h", Lessons = 14, Students = 64, Certificates = 22, Progress = 71, Status = "Publicado", Color = "purple" },
        new { Icon = "🗣️", Title = "Comunicação Não Violenta", Category = "Relacionamentos", Teacher = "Terapia de Grupo", Hours = "14h", Lessons = 9, Students = 39, Certificates = 12, Progress = 55, Status = "Rascunho", Color = "rose" },
        new { Icon = "🌱", Title = "Autoconhecimento e Responsabilidade", Category = "Recuperação", Teacher = "Equipe Clínica", Hours = "22h", Lessons = 16, Students = 78, Certificates = 28, Progress = 80, Status = "Publicado", Color = "cyan" }
    };
}

<section style="padding: 32px; background: #f3f4f6; min-height: 100vh;">
    <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:24px; margin-bottom:28px; flex-wrap:wrap;">
        <div>
            <span style="color:#2563eb; font-weight:700; font-size:14px; text-transform:uppercase; letter-spacing:.08em;">Plataforma EAD</span>
            <h1 style="font-size:34px; font-weight:800; color:#111827; margin:8px 0;">Biblioteca de Cursos</h1>
            <p style="color:#6b7280; font-size:16px; max-width:760px;">
                Cursos preparados para apoiar o processo de recuperação, desenvolvimento pessoal e reinserção social dos acolhidos.
            </p>
        </div>

        <a asp-area="EAD" asp-controller="Courses" asp-action="Create"
           style="background:#2563eb; color:white; padding:14px 22px; border-radius:16px; text-decoration:none; font-weight:700; box-shadow:0 10px 24px rgba(37,99,235,.25);">
            + Novo Curso
        </a>
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:18px; margin-bottom:28px;">
        <div style="background:white; border-radius:22px; padding:22px; box-shadow:0 10px 30px rgba(15,23,42,.06);">
            <span style="color:#6b7280;">Cursos publicados</span>
            <strong style="display:block; font-size:32px; color:#111827; margin-top:8px;">18</strong>
            <small style="color:#10b981; font-weight:700;">+4 este mês</small>
        </div>
        <div style="background:white; border-radius:22px; padding:22px; box-shadow:0 10px 30px rgba(15,23,42,.06);">
            <span style="color:#6b7280;">Alunos estudando</span>
            <strong style="display:block; font-size:32px; color:#111827; margin-top:8px;">94</strong>
            <small style="color:#2563eb; font-weight:700;">72% engajados</small>
        </div>
        <div style="background:white; border-radius:22px; padding:22px; box-shadow:0 10px 30px rgba(15,23,42,.06);">
            <span style="color:#6b7280;">Certificados emitidos</span>
            <strong style="display:block; font-size:32px; color:#111827; margin-top:8px;">197</strong>
            <small style="color:#10b981; font-weight:700;">34 este mês</small>
        </div>
        <div style="background:white; border-radius:22px; padding:22px; box-shadow:0 10px 30px rgba(15,23,42,.06);">
            <span style="color:#6b7280;">Progresso médio</span>
            <strong style="display:block; font-size:32px; color:#111827; margin-top:8px;">78%</strong>
            <small style="color:#f59e0b; font-weight:700;">acima da meta</small>
        </div>
    </div>

    <div style="background:white; border-radius:24px; padding:18px; box-shadow:0 10px 30px rgba(15,23,42,.06); margin-bottom:28px; display:flex; gap:14px; flex-wrap:wrap; align-items:center;">
        <input type="text" placeholder="Pesquisar curso, categoria ou professor..."
               style="flex:1; min-width:260px; padding:14px 16px; border-radius:16px; border:1px solid #e5e7eb; outline:none;" />
        <select style="padding:14px 16px; border-radius:16px; border:1px solid #e5e7eb; color:#374151;">
            <option>Todos os status</option>
            <option>Publicado</option>
            <option>Rascunho</option>
            <option>Arquivado</option>
        </select>
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:24px;">
        @foreach (var course in courses)
        {
            <article style="background:white; border-radius:28px; overflow:hidden; box-shadow:0 14px 35px rgba(15,23,42,.08); border:1px solid #eef2f7;">
                <div style="height:130px; background:linear-gradient(135deg,#2563eb,#10b981); display:flex; align-items:center; justify-content:center;">
                    <span style="font-size:56px;">@course.Icon</span>
                </div>

                <div style="padding:24px;">
                    <div style="display:flex; justify-content:space-between; align-items:center; gap:12px; margin-bottom:14px;">
                        <span style="background:#eff6ff; color:#2563eb; padding:7px 12px; border-radius:999px; font-size:12px; font-weight:800;">
                            @course.Category
                        </span>

                        <span style="background:@(course.Status == "Publicado" ? "#dcfce7" : "#fef3c7"); color:@(course.Status == "Publicado" ? "#166534" : "#92400e"); padding:7px 12px; border-radius:999px; font-size:12px; font-weight:800;">
                            @course.Status
                        </span>
                    </div>

                    <h2 style="font-size:21px; font-weight:800; color:#111827; margin:0 0 10px;">
                        @course.Title
                    </h2>

                    <p style="color:#6b7280; line-height:1.5; margin-bottom:18px;">
                        Curso com abordagem prática para fortalecer a recuperação, disciplina, autonomia e desenvolvimento pessoal.
                    </p>

                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:18px;">
                        <div style="background:#f9fafb; border-radius:16px; padding:12px;">
                            <small style="color:#6b7280;">Professor</small>
                            <strong style="display:block; color:#111827; margin-top:3px;">@course.Teacher</strong>
                        </div>
                        <div style="background:#f9fafb; border-radius:16px; padding:12px;">
                            <small style="color:#6b7280;">Carga horária</small>
                            <strong style="display:block; color:#111827; margin-top:3px;">@course.Hours</strong>
                        </div>
                    </div>

                    <div style="margin-bottom:18px;">
                        <div style="display:flex; justify-content:space-between; color:#374151; font-size:14px; margin-bottom:8px;">
                            <span>Progresso médio</span>
                            <strong>@course.Progress%</strong>
                        </div>
                        <div style="height:10px; background:#e5e7eb; border-radius:999px; overflow:hidden;">
                            <div style="height:10px; width:@course.Progress%; background:linear-gradient(90deg,#2563eb,#10b981); border-radius:999px;"></div>
                        </div>
                    </div>

                    <div style="display:flex; justify-content:space-between; gap:10px; color:#6b7280; font-size:14px; margin-bottom:22px;">
                        <span>📘 @course.Lessons aulas</span>
                        <span>👥 @course.Students alunos</span>
                        <span>🎓 @course.Certificates certificados</span>
                    </div>

                    <div style="display:flex; gap:10px;">
                        <a asp-area="EAD" asp-controller="Courses" asp-action="Details"
                           style="flex:1; text-align:center; padding:12px; border-radius:14px; background:#2563eb; color:white; text-decoration:none; font-weight:800;">
                            Abrir
                        </a>
                        <a asp-area="EAD" asp-controller="Courses" asp-action="Edit"
                           style="flex:1; text-align:center; padding:12px; border-radius:14px; background:#f3f4f6; color:#374151; text-decoration:none; font-weight:800;">
                            Editar
                        </a>
                    </div>
                </div>
            </article>
        }
    </div>
</section>